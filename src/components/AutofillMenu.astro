---
import Menu from './Menu.astro';

interface Props {
  id?: string;
  class?: string;
  ariaLabel?: string;
  maxHeight?: string;
  zIndex?: string | number;
}

const {
  id = '',
  class: className = '',
  ariaLabel = '',
  maxHeight = '224px',
  zIndex = '4000',
} = Astro.props;
---

<Menu id={id} class={`autofill-menu ${className}`} ariaLabel={ariaLabel} maxHeight={maxHeight} zIndex={zIndex}>
  <slot />
</Menu>

<style>
  :global(.autofill-menu) {
    transition: none !important;
  }

  :global(.autofill-menu.menu--closing) {
    transition: none !important;
  }

  :global(.autofill-menu .menu__content) {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  :global(.autofill-menu .menu__content::-webkit-scrollbar) {
    display: none;
  }

  :global(.autofill-menu .menu__list) {
    min-width: var(--autofill-menu-width, 240px);
    width: var(--autofill-menu-width, 240px);
  }

  :global(.autofill-menu__option) {
    list-style: none;
  }

  :global(.autofill-menu__item) {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    width: 100%;
    height: 36px;
    padding: 0 12px;
    gap: 8px;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: var(--text);
    background: transparent;
    border: none;
    border-radius: 999px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
    user-select: none;
    -webkit-user-drag: none;
    outline: none;
  }

  @media (hover: hover) {
    :global(.autofill-menu__item:hover) {
      background: var(--border-strong);
    }
  }

  :global(.autofill-menu__item:active) {
    opacity: 0.6;
  }

  :global(.autofill-menu__item.is-active) {
    background: var(--border);
    color: var(--color-primary-500);
  }

  :global(.autofill-menu__item span) {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: left;
  }
</style>
