---
// Figma: Pill — 可复用的胶囊背景控件
//
// 封装 45° 渐变边框、阴影、背景模糊 等通用 Pill 样式。
//
// 架构：视觉层与布局层剥离
//   .pill                → 布局容器（position/transform/border-radius/交互态）
//                           无 overflow:hidden → fixed/absolute 子元素不被裁剪
//   .pill__bg-layer      → 视觉背景层（绝对定位占满父级）
//                           负责 background / box-shadow / backdrop-filter
//                           overflow:hidden 仅在此层，glow 放入此层裁剪圆角
//
// Props:
//   primary  — true 时使用主题主色背景
//   flat     — true 时阴影变浅
//   class    — 附加 CSS 类
//   id       — DOM id

interface Props {
  primary?: boolean;
  flat?: boolean;
  panel?: boolean;
  noDrag?: boolean;
  class?: string;
  id?: string;
}

const { primary = false, flat = false, panel = false, noDrag = false, class: className = '', id = '' } = Astro.props;
---

<div
  id={id}
  class={`pill ${primary ? 'pill--primary' : ''} ${flat ? 'pill--flat' : ''} ${panel ? 'pill--panel' : ''} ${className}`}
data-no-drag={noDrag || undefined}
>
  <!-- 视觉背景层：背景色/阴影/模糊/渐变边框/glow → 在此处被 overflow:hidden 裁剪 -->
  <span class="pill__bg-layer" aria-hidden="true">
    <span class="pill__glow" aria-hidden="true"></span>
  </span>
  <!-- 内容层：不受 overflow 限制，slot 内的 fixed 子菜单可自由漂移 -->
  <slot />
</div>

<style>
  /* ======== 布局容器 ======== */
  .pill {
    display: inline-flex;
    align-items: center;
    /* justify-content: center; */
    position: relative;
    z-index: 0;
    border-radius: var(--pill-radius, 24px);
    border: none;

    transition:
      background-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.2s ease;
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-user-drag: none;
    user-drag: none;
  }

  /* noDrag 时恢复浏览器默认触摸行为 */
  .pill[data-no-drag] {
    touch-action: auto;
  }

  /* 菜单触发按钮隐藏态 — 向菜单位置/大小过渡（覆盖 Pill 的弹簧曲线） */
  .pill.is-trigger-hidden {
    opacity: 0;
    transform: translate(var(--move-x, 0px), var(--move-y, 0px)) scale(var(--scale-x, 1.25), var(--scale-y, 1.25)) !important;
    pointer-events: none;
    transition:
      transform 0.25s cubic-bezier(0.34, 1.34, 0.64, 1),
      opacity 0.2s ease;
  }

  /* 按下放大（纯点击不拖拽时生效） */
  .pill.is-pressed {
    transform: scale(1.08);
  }

  /* 拖拽中禁用 transition，保证手感跟手 */
  .pill--dragging {
    transition: transform 0ms !important;
  }

  /* ======== 视觉背景层 ========
     所有视觉装饰都在此层，overflow:hidden 仅限这里 */
  .pill__bg-layer {
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    overflow: hidden;
    background: var(--pill-bg);
    box-shadow: 0 8px 12px var(--pill-shadow);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    pointer-events: none;
  }

  /* 渐变边框 via ::before (45°) — 挂在 bg-layer 上 */
  .pill__bg-layer::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    padding: 2px;
    background: var(--border-gradient);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  /* ======== primary 变体 ======== */
  .pill--primary .pill__bg-layer {
    background: var(--pill-primary-bg);
  }

  /* ======== flat 变体 ======== */
  .pill--flat .pill__bg-layer {
    box-shadow: 0 2px 6px var(--pill-shadow);
  }

  /* ======== panel 变体 — 更高模糊 + 更高 alpha 背景 ======== */
  .pill--panel .pill__bg-layer {
    background: var(--pill-bg-panel);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  /* ======== hover 背景状态（仅支持 hover 的设备，如 PC 鼠标） ======== */
  @media (hover: hover) {
    .pill:not(.pill--primary):hover .pill__bg-layer {
      background: var(--pill-bg-hover);
    }

    .pill--primary:hover .pill__bg-layer {
      background: var(--pill-primary-bg-hover);
    }

    .pill--flat.pill--primary:hover .pill__bg-layer {
      background: color-mix(in srgb, var(--color-primary-500) 90%, transparent);
    }
  }

  /* ======== active 背景状态（触屏 & 鼠标通用） ======== */
  .pill:not(.pill--primary):active .pill__bg-layer {
    background: var(--pill-bg-active);
  }

  .pill--primary:active .pill__bg-layer {
    background: var(--pill-primary-bg-active);
  }

  .pill--flat.pill--primary:active .pill__bg-layer {
    background: var(--pill-primary-bg);
  }

  /* ======== panel 变体 hover/active 保持 panel 背景 ======== */
  .pill--panel:not(.pill--primary):hover .pill__bg-layer {
    background: var(--pill-bg-panel);
  }

  .pill--panel:not(.pill--primary):active .pill__bg-layer {
    background: var(--pill-bg-panel);
  }

  /* ======== Press Glow ======== */
  .pill__glow {
    position: absolute;
    z-index: 1;
    width: 78px;
    height: 78px;
    border-radius: 50%;
    background: var(--glow);
    filter: blur(32px);
    -webkit-filter: blur(32px);
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -50%);
    will-change: left, top, opacity;

    transition: opacity 300ms cubic-bezier(0.4, 0, 1, 1);
  }

  .pill__glow.is-visible {
    opacity: 1;
    transition: opacity 150ms cubic-bezier(.16,.49,0,.99);
  }
</style>

<script is:inline>
  // Press Glow & Drag — 按下缩放 + 拖拽位移/形变, 释放时弹回
  (function () {
    function $(el, sel) { return el && el.closest ? el.closest(sel) : null; }

    document.addEventListener('pointerdown', function (e) {
      var pill = $(e.target, '.pill');
      if (!pill) return;
      if (pill.hasAttribute('data-no-drag')) return;
      var glow = pill.querySelector('.pill__glow');
      if (!glow) return;
      if (pill.classList.contains('pill--dragging')) return;

      var startX = e.clientX;
      var startY = e.clientY;
      var rect   = pill.getBoundingClientRect();

      enter(pill, glow, rect, e);

      function onMove(ev) { move(pill, glow, startX, startY, ev); }
      function onUp()     { leave(pill, glow); cleanup(); }

      function cleanup() {
        document.removeEventListener('pointermove', onMove);
        document.removeEventListener('pointerup', onUp);
        document.removeEventListener('pointerleave', onUp);
      }

      document.addEventListener('pointermove', onMove);
      document.addEventListener('pointerup', onUp);
      document.addEventListener('pointerleave', onUp);
    });

    function enter(pill, glow, rect, e) {
      var pressScale = Number(getComputedStyle(pill).getPropertyValue('--pill-press-scale')) || 1.08;
      pill.classList.add('is-pressed');
      pill.style.transform = 'scale(' + pressScale + ')';
      glow.classList.add('is-visible');
      glow.style.left = (e.clientX - rect.left) + 'px';
      glow.style.top  = (e.clientY - rect.top) + 'px';
    }

    function move(pill, glow, sx, sy, e) {
      if (!pill.classList.contains('pill--dragging')) {
        var cur = getComputedStyle(pill).transform;
        pill.classList.remove('is-pressed');
        pill.classList.add('pill--dragging');
        var pressScale = Number(getComputedStyle(pill).getPropertyValue('--pill-press-scale')) || 1.08;
        pill.style.transform = cur !== 'none' ? cur : 'scale(' + pressScale + ')';
        requestAnimationFrame(function () { computeDrag(pill, glow, sx, sy, e); });
        return;
      }
      computeDrag(pill, glow, sx, sy, e);
    }

    function computeDrag(pill, glow, sx, sy, e) {
      var dx  = e.clientX - sx;
      var dy  = e.clientY - sy;

      var maxDisp = 6;
      var tx = Math.sign(dx) * maxDisp * (1 - 1 / (1 + Math.abs(dx) / 80));
      var ty = Math.sign(dy) * maxDisp * (1 - 1 / (1 + Math.abs(dy) / 80));

      var dragScale = Number(getComputedStyle(pill).getPropertyValue('--pill-drag-scale')) || 0.08;
      var scaleX = 1 + dragScale / (1 + Math.abs(dy) / 120);
      var scaleY = 1 + dragScale / (1 + Math.abs(dx) / 120);

      pill.style.transform = 'translate(' + tx + 'px, ' + ty + 'px) scale(' + scaleX + ', ' + scaleY + ')';

      var r = pill.getBoundingClientRect();
      glow.style.left = (e.clientX - r.left) + 'px';
      glow.style.top  = (e.clientY - r.top) + 'px';
    }

    function leave(pill, glow) {
      pill.classList.remove('pill--dragging');
      pill.classList.remove('is-pressed');
      pill.style.transform = '';
      glow.classList.remove('is-visible');
    }
  })();
</script>
