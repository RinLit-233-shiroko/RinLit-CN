---
import { t } from '../../i18n/index';
import Link from '../Link.astro';

interface Props {
  lang?: string;
}

const { lang } = Astro.props;
const __ = (key: string) => t(lang, key);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center gap-6">
      <img
        class="footer-logo footer-logo--light"
        src="/images/logo/Type=Horizontal, Mode=Light, Monochrome=True.png"
        alt="RinLit"
      />
      <img
        class="footer-logo footer-logo--dark"
        src="/images/logo/Type=Horizontal, Mode=Dark, Monochrome=True.png"
        alt="RinLit"
      />

      <nav class="flex flex-wrap justify-center gap-6 text-body">
        <Link to="fields" class="footer-link">{__('nav.fields')}</Link>
        <Link to="gallery" class="footer-link">{__('nav.gallery')}</Link>
        <Link to="writing" class="footer-link">{__('nav.writing')}</Link>
        <Link to="me" class="footer-link">{__('nav.me')}</Link>
      </nav>

      <p class="footer-copy text-caption">
        {__('footer.copyright').replace('{year}', String(year))}
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--footer-bg);
    color: var(--text);
    padding-top: 48px;
    padding-bottom: 112px;
    transition: background-color 0.25s ease, color 0.25s ease;
  }

  @media (min-width: 769px) {
    .site-footer {
      padding-bottom: 48px;
    }
  }

  .footer-logo {
    height: 32px;
    width: auto;
  }
  .footer-logo--light { display: var(--logo-light-display); }
  .footer-logo--dark { display: var(--logo-dark-display); }

  .footer-link {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }
  .footer-link:hover {
    opacity: 0.7;
  }

  .footer-copy {
    opacity: 0.5;
  }
</style>
