---
import Pill from './Pill.astro';

interface Props {
  value?: string;
  placeholder?: string;
  label?: string;
  name?: string;
  required?: boolean;
  autofocus?: boolean;
  error?: string;
  flat?: boolean;
  class?: string;
  id?: string;
  rows?: number;
}

const {
  value = '',
  placeholder = '',
  label = '',
  name = '',
  required = false,
  autofocus = false,
  error = '',
  flat = false,
  class: className = '',
  id = '',
  rows = 4,
} = Astro.props;

const textareaId = id || (name ? `textarea-${name}` : `textarea-${Math.random().toString(36).slice(2)}`);
---

<div class={`textarea-wrap ${error ? 'textarea-wrap--error' : ''} ${className}`}>
  {label && (
    <label class="textarea-label" for={textareaId}>{label}</label>
  )}

  <Pill flat={flat} class={`textarea-field-pill ${error ? 'textarea-field-pill--error' : ''}`}>
    <textarea
      id={textareaId}
      name={name}
      placeholder={placeholder}
      required={required}
      autofocus={autofocus}
      rows={rows}
      class="textarea-field"
      aria-invalid={error ? 'true' : 'false'}
      aria-describedby={error ? `${textareaId}-error` : undefined}
    >{value}</textarea>
  </Pill>

  {error && (
    <p class="textarea-error" id={`${textareaId}-error`} role="alert">{error}</p>
  )}
</div>

<style>
  .textarea-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .textarea-label {
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: var(--text);
    padding-left: 4px;
    transition: color 0.2s ease;
  }

  :global(.textarea-field-pill) {
    --pill-radius: 24px;
    --pill-press-scale: 1.01;
    --pill-drag-scale: 0.01;
    display: flex;
    align-items: stretch;
  }

  .textarea-field {
    position: relative;
    z-index: 1;
    width: 100%;
    min-height: 112px;
    padding: 14px 16px;
    background: transparent;
    border: none;
    border-radius: 14px;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 500;
    font-size: 15px;
    line-height: 1.55;
    color: var(--text-strong);
    outline: none;
    box-sizing: border-box;
    resize: vertical;
  }

  .textarea-field::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }

  :global(.textarea-field-pill--error) {
    box-shadow: 0 0 0 1.5px rgba(220, 38, 38, 0.45);
    border-radius: 14px;
  }

  .textarea-wrap--error:focus-within :global(.textarea-field-pill--error) {
    box-shadow: 0 0 0 2px rgba(220, 38, 38, 0.55);
  }

  .textarea-error {
    margin: 0;
    padding-left: 4px;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 500;
    font-size: 12px;
    color: #dc2626;
  }

  :root.dark :global(.textarea-field-pill--error) {
    box-shadow: 0 0 0 1.5px rgba(239, 68, 68, 0.5);
  }
</style>
