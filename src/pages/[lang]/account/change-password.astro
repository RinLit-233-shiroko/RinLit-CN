---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import Input from '../../../components/Input.astro';
import { t, locales } from '../../../i18n/index';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang = 'zh-cn' } = Astro.params;
const __ = (key: string) => t(lang, key);
const isZh = lang === 'zh-cn';
---

<BaseLayout
  lang={lang}
  title={__('auth.updatePassword')}
  description={isZh ? '验证当前密码并设置新密码。' : 'Verify current password and set a new password.'}
>
  <section class="account-action-page">
    <div class="account-action-header">
      <a class="account-logo" href={`/${lang}/account`} aria-label={isZh ? '返回账号' : 'Back to account'}>
        <img class="account-logo__img account-logo__img--light" src="/images/logo/Type=Horizontal, Mode=Light, Monochrome=False.png" alt="RinLit" />
        <img class="account-logo__img account-logo__img--dark" src="/images/logo/Type=Horizontal, Mode=Dark, Monochrome=False.png" alt="RinLit" />
        <span>{__('auth.account')}</span>
      </a>
    </div>

    <main class="account-action-card" id="change-password-card" hidden>
      <div class="account-action-title">
        <p>{isZh ? '登录和安全' : 'Sign-in & Security'}</p>
        <h1>{__('auth.updatePassword')}</h1>
      </div>

      <form class="account-action-form" id="change-password-form">
        <Input
          type="password"
          name="current-password"
          id="current-password"
          label={isZh ? '当前密码' : 'Current password'}
          placeholder="········"
          autocomplete="current-password"
          flat
          required
        />
        <Input
          type="password"
          name="new-password"
          id="new-password"
          label={__('auth.newPassword')}
          placeholder={__('auth.passwordSignupPlaceholder')}
          autocomplete="new-password"
          flat
          required
        />
        <p class="account-action-message" id="change-password-message" role="status"></p>
        <Button primary flat class="account-action-submit" id="password-submit-btn">
          <span id="password-submit-label">{__('auth.updatePasswordAction')}</span>
          <span class="btn-spinner" id="password-submit-spinner" hidden>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            </svg>
          </span>
        </Button>
      </form>
    </main>
  </section>
</BaseLayout>

<script is:inline define:vars={{
  __CHANGE_PASSWORD_I18N: JSON.stringify({
    required: __('auth.error.required'),
    passwordLength: __('auth.error.password_length'),
    defaultError: __('auth.error.default'),
    invalidCredentials: __('auth.error.invalid_credentials'),
    saving: isZh ? '修改中...' : 'Updating...',
    saved: __('auth.passwordUpdated'),
    submit: __('auth.updatePasswordAction'),
  })
}}>
  window.__CHANGE_PASSWORD_I18N = JSON.parse(__CHANGE_PASSWORD_I18N);
</script>

<script>
  import { getUser, verifyPassword, updatePassword } from '../../../lib/auth.client';

  const text = (window as any).__CHANGE_PASSWORD_I18N || {};
  let currentEmail = '';

  const card = document.getElementById('change-password-card')!;
  const form = document.getElementById('change-password-form') as HTMLFormElement;
  const currentPasswordInput = document.getElementById('current-password') as HTMLInputElement;
  const newPasswordInput = document.getElementById('new-password') as HTMLInputElement;
  const message = document.getElementById('change-password-message')!;
  const submitLabel = document.getElementById('password-submit-label')!;
  const submitSpinner = document.getElementById('password-submit-spinner')!;
  const submitBtn = document.getElementById('password-submit-btn') as HTMLElement;

  function setMessage(value: string, type = 'neutral') {
    message.textContent = value;
    message.setAttribute('data-type', type);
  }

  async function loadPage() {
    const { user } = await getUser();
    if (!user?.email) {
      const next = encodeURIComponent(window.location.pathname + window.location.search);
      window.location.replace(`/${document.documentElement.lang}/account/redirect?next=${next}`);
      return;
    }

    currentEmail = user.email;
    card.hidden = false;
  }

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const currentPassword = currentPasswordInput.value;
    const newPassword = newPasswordInput.value;

    if (!currentPassword || !newPassword) {
      setMessage(text.required, 'error');
      return;
    }

    if (newPassword.length < 6) {
      setMessage(text.passwordLength, 'error');
      return;
    }

    submitLabel.hidden = true;
    submitSpinner.hidden = false;
    submitBtn.setAttribute('aria-disabled', 'true');
    setMessage('', 'neutral');

    const verifyResult = await verifyPassword(currentEmail, currentPassword);
    if (verifyResult.error) {
      setMessage(text.invalidCredentials, 'error');
      submitLabel.hidden = false;
      submitSpinner.hidden = true;
      submitBtn.removeAttribute('aria-disabled');
      return;
    }

    const { error } = await updatePassword(newPassword);
    if (error) {
      setMessage(error.message || text.defaultError, 'error');
    } else {
      setMessage(text.saved, 'success');
      form.reset();
    }

    submitLabel.hidden = false;
    submitSpinner.hidden = true;
    submitBtn.removeAttribute('aria-disabled');
  });

  document.addEventListener('auth:signed-in', loadPage);
  document.addEventListener('astro:page-load', loadPage);
  loadPage();
</script>

<style>
  .account-action-page {
    min-height: 100vh;
    padding: 104px clamp(20px, 4vw, 48px) 80px;
    background: var(--bg);
  }

  .account-action-header {
    max-width: 1400px;
    margin-inline: auto;
  }

  .account-action-card {
    max-width: 640px;
    margin-inline: auto;
  }

  .account-action-header {
    margin-bottom: 44px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 16px;
  }

  .account-logo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-strong);
    text-decoration: none;
    font-size: 22px;
    font-weight: 800;
  }

  .account-logo__img {
    width: 96px;
    height: auto;
    display: block;
  }

  .account-logo__img--light { display: var(--logo-light-display); }
  .account-logo__img--dark { display: var(--logo-dark-display); }

  .account-action-card {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    padding: 26px;
    box-shadow: 0 10px 28px color-mix(in srgb, var(--shadow-color) 24%, transparent);
  }

  .account-action-title {
    margin-bottom: 24px;
  }

  .account-action-title p {
    margin: 0 0 8px;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 700;
  }

  .account-action-title h1,
  .account-action-locked h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: 32px;
    line-height: 1.16;
  }

  .account-action-form {
    display: grid;
    gap: 16px;
  }

  .account-action-message {
    min-height: 20px;
    margin: 0;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 600;
  }

  .account-action-message[data-type='success'] { color: #059669; }
  .account-action-message[data-type='error'] { color: #dc2626; }

  .account-action-submit,
  .account-action-submit :global(.btn) {
    width: 100%;
  }

  /* 进度环 */
  .btn-spinner svg {
    animation: btn-spin 0.8s linear infinite;
    display: block;
  }

  @keyframes btn-spin {
    to { transform: rotate(360deg); }
  }

  .account-action-locked {
    text-align: center;
  }

  .account-action-locked p {
    margin: 12px 0 22px;
    color: var(--text-muted);
    font-weight: 600;
  }
</style>
