---
import { locales } from '../../../i18n/index';
import { t } from '../../../i18n/index';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Link from '../../../components/Link.astro';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const __ = (key: string) => t(lang, key);
---

<BaseLayout lang={lang} title={`${__('page.fields.software.title')} — Fields — RinLit`}>
  <main class="mx-auto flex min-h-screen max-w-5xl items-center px-6">
    <div>
      <p class="text-section-label font-display uppercase tracking-[0.25em] text-primary-600">{__('page.fields.software.breadcrumb')}</p>
      <h1 class="mt-4 text-hero font-display tracking-tight text-dark">{__('page.fields.software.title')}</h1>
      <p class="mt-6 text-body-large text-neutral-800">{__('page.fields.software.desc')}</p>
      <Link to="fields" class="mt-8 inline-block text-body text-primary-600 hover:underline">&larr; {__('back')}</Link>
    </div>
  </main>
</BaseLayout>
