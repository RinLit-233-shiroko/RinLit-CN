---
// UpdatePasswordPage — 修改密码页面
//
// 用户通过密码重置邮件中的链接跳转至此页面。
// 页面会从 URL hash 中读取 Supabase session（PKCE flow），
// 然后允许用户设置新密码。
//
// 该 URL 需要在 Supabase Dashboard > Authentication > Redirect URLs 中注册:
//   http://localhost:4321/[lang]/account/update-password

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import Input from '../../../components/Input.astro';
import { t, locales } from '../../../i18n/index';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const __ = (key: string) => t(lang, key);
---

<BaseLayout
  lang={lang}
  title={__('auth.updatePassword')}
  description={__('auth.updatePassword')}
>
  <main class="update-password-page">
    <div class="update-password-card">
      <div class="update-password-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
      </div>

      <h1 class="update-password-title">{__('auth.updatePassword')}</h1>

      <!-- 成功提示（初始隐藏） -->
      <div class="update-password-success" id="update-password-success" hidden>
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6L9 17l-5-5" />
        </svg>
        <h2>{__('auth.passwordUpdated')}</h2>
        <p>{__('auth.passwordUpdatedDesc')}</p>
      </div>

      <!-- 密码表单 -->
      <div class="update-password-form" id="update-password-form">
        <div class="update-password-field">
          <Input
            type="password"
            name="new-password"
            id="new-password"
            placeholder="········"
            label={__('auth.newPassword')}
            flat
            required
            autocomplete="new-password"
          />
        </div>

        <p class="update-password-error" id="update-password-error" hidden></p>

        <div class="update-password-action">
          <Button primary flat class="update-password-submit-btn">
            <span class="update-password-submit-label">{__('auth.updatePasswordAction')}</span>
            <span class="update-password-submit-spinner" hidden>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              </svg>
            </span>
          </Button>
        </div>
      </div>

      <!-- 验证中加载态 -->
      <div class="update-password-loading" id="update-password-loading" hidden>
        <p>{__('auth.loading')}</p>
      </div>
    </div>
  </main>
</BaseLayout>

<script is:inline define:vars={{
  __SUPABASE_URL: import.meta.env.PUBLIC_SUPABASE_URL,
  __SUPABASE_KEY: import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY,
  __I18N_DATA: JSON.stringify({
    __required: __('auth.error.required'),
    __password_length: __('auth.error.password_length'),
    __default: __('auth.error.default'),
  })
}}>
  window.__SUPABASE_URL = __SUPABASE_URL;
  window.__SUPABASE_KEY = __SUPABASE_KEY;
  window.__AUTH_I18N = JSON.parse(__I18N_DATA);
</script>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient((window as any).__SUPABASE_URL, (window as any).__SUPABASE_KEY);
  const i18n = (window as any).__AUTH_I18N || {};

  const $form = document.getElementById('update-password-form')!;
  const $success = document.getElementById('update-password-success')!;
  const $loading = document.getElementById('update-password-loading')!;
  const $error = document.getElementById('update-password-error')!;
  const $passwordInput = document.getElementById('new-password') as HTMLInputElement;
  const $submitBtn = document.querySelector('.update-password-submit-btn') as HTMLElement;

  function showError(msg: string) {
    $error.textContent = msg;
    $error.hidden = false;
  }

  function hideError() {
    $error.hidden = true;
    $error.textContent = '';
  }

  // Supabase PKCE: 从 URL hash 中恢复 session
  async function initializeSession() {
    $loading.hidden = false;
    $form.hidden = true;
    $success.hidden = true;

    try {
      const { data, error } = await supabase.auth.getSession();

      if (error) {
        showError(error.message);
        $loading.hidden = true;
        $form.hidden = false;
        return;
      }

      if (!data.session) {
        // 尝试从 URL hash 解析 session
        const hash = window.location.hash;
        if (hash && hash.includes('type=recovery')) {
          // 该会话可以通过 supabase.auth.onAuthStateChange 自动恢复
          // 等待 auth state 更新
          await new Promise<void>((resolve) => {
            const { data: listener } = supabase.auth.onAuthStateChange((event, session) => {
              if (session) {
                listener?.subscription.unsubscribe();
                resolve();
              }
            });
            // 超时保护
            setTimeout(resolve, 5000);
          });
        } else {
          showError('Invalid or expired reset link. Please request a new password reset.');
          $loading.hidden = true;
          $form.hidden = false;
          return;
        }
      }

      $loading.hidden = true;
      $form.hidden = false;
    } catch (err: any) {
      showError(err.message || 'An error occurred.');
      $loading.hidden = true;
      $form.hidden = false;
    }
  }

  async function handleUpdatePassword() {
    hideError();
    const password = $passwordInput.value;

    if (!password) {
      showError(i18n.__required || 'Please fill in all fields.');
      return;
    }

    if (password.length < 6) {
      showError(i18n.__password_length || 'Password must be at least 6 characters.');
      return;
    }

    $submitBtn.setAttribute('disabled', '');
    const submitLabels = document.querySelectorAll('.update-password-submit-label') as NodeListOf<HTMLElement>;
    const submitSpinner = document.querySelector('.update-password-submit-spinner') as HTMLElement;
    submitLabels.forEach(l => l.hidden = true);
    if (submitSpinner) submitSpinner.hidden = false;

    try {
      const { error } = await supabase.auth.updateUser({ password });

      if (error) {
        showError(error.message);
      } else {
        // 密码更新成功 → 登出 + 重定向到首页
        $form.hidden = true;
        $success.hidden = false;
        await supabase.auth.signOut();
        setTimeout(() => {
          const lang = window.location.pathname.split('/')[1] || 'zh-cn';
          window.location.href = `/${lang}`;
        }, 2000);
      }
    } catch (err: any) {
      showError(err.message || 'An error occurred.');
    } finally {
      $submitBtn.removeAttribute('disabled');
      submitLabels.forEach(l => l.hidden = false);
      if (submitSpinner) submitSpinner.hidden = true;
    }
  }

  // 初始化
  initializeSession();

  // 绑定提交事件
  $submitBtn.addEventListener('click', (e) => {
    e.preventDefault();
    handleUpdatePassword();
  });

  $passwordInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      handleUpdatePassword();
    }
  });
</script>

<style is:global>
  .update-password-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 160px);
    padding: 48px 24px;
  }

  .update-password-card {
    width: 380px;
    max-width: 100%;
    background: var(--bg-elevated);
    border-radius: 24px;
    padding: 40px 32px 32px;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      0 20px 60px rgba(0, 0, 0, 0.3);
    text-align: center;
  }

  .update-password-icon {
    display: flex;
    justify-content: center;
    color: var(--color-primary-500);
    margin-bottom: 16px;
  }

  .update-password-title {
    margin: 0 0 24px;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 700;
    font-size: 22px;
    color: var(--text-strong);
  }

  .update-password-field {
    margin-bottom: 4px;
  }

  .update-password-error {
    margin: 8px 0 0;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 500;
    font-size: 13px;
    color: #ef4444;
    text-align: center;
    min-height: 18px;
  }

  .update-password-action {
    margin-top: 16px;
  }

  .update-password-submit-spinner svg {
    animation: auth-spin 0.8s linear infinite;
    display: block;
  }

  @keyframes auth-spin {
    to { transform: rotate(360deg); }
  }

  .update-password-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 24px 0;
  }

  .update-password-success h2 {
    margin: 0;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 700;
    font-size: 18px;
    color: var(--text-strong);
  }

  .update-password-success p {
    margin: 0;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 500;
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .update-password-loading {
    padding: 40px 0;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 500;
    font-size: 14px;
    color: var(--text-muted);
  }

  .update-password-loading[hidden] {
    display: none !important;
  }
</style>
