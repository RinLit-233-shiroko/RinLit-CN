---
// AuthPasswordPage — 密码输入页面（Page 1）
//
// 登录/注册共用。通过 data-label-* 属性 + is-hidden 类在客户端切换按钮文案。

import { t } from '../../../i18n/index';
import Input from '../../../components/Input.astro';
import Button from '../../../components/Button.astro';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const __ = (key: string) => t(lang, key);
---

<div data-page="1" class="auth-modal__page">
  <div class="auth-modal__email-display" id="auth-email-display">
    <svg class="auth-modal__email-display-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
      <circle cx="12" cy="7" r="4" />
    </svg>
    <span class="auth-modal__email-display-text"></span>
  </div>

  <!-- DisplayName（仅注册时显示） -->
  <div class="auth-modal__field" data-label-signup>
    <Input
      type="text"
      name="display-name"
      id="auth-display-name"
      placeholder={__('auth.displayNamePlaceholder')}
      label={__('auth.displayName')}
      flat
      autocomplete="name"
    />
  </div>

  <div class="auth-modal__field">
    <Input
      type="password"
      name="password"
      id="auth-password"
      placeholder="········"
      label={__('auth.password')}
      flat
      required
      autocomplete="current-password"
    />
  </div>

  <p class="auth-modal__error" id="auth-error-password" hidden></p>

  <div class="auth-modal__forgot-link-wrap" data-label-signin>
    <button class="auth-modal__forgot-link" data-action="auth:forgot" type="button">
      {__('auth.forgotPassword')}
    </button>
  </div>

  <div class="auth-modal__action">
    <Button primary flat class="auth-modal__submit-btn">
      <span class="auth-modal__submit-label" data-label-signin>{__('auth.signInAction')}</span>
      <span class="auth-modal__submit-label" data-label-signup class="is-hidden">{__('auth.signUpAction')}</span>
      <span class="auth-modal__submit-spinner" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
      </span>
    </Button>
  </div>
</div>
