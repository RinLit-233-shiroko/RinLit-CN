---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import SettingsCard from '../../../components/SettingsCard.astro';
import Textarea from '../../../components/Textarea.astro';
import NavigationBar from '../../../components/NavigationBar.astro';
import ModerationToolbar from '../../../components/gallery/ModerationToolbar.astro';
import { getIcon } from '../../../utils/icons';
import { locales, t } from '../../../i18n/index';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang = 'zh-cn' } = Astro.params;
const __ = (key: string) => t(lang, key);
const icons = {
  list: getIcon('layout-list', 18),
  grid: getIcon('layout-grid', 18),
};
---

<BaseLayout lang={lang} title={`${__('gallery.managePage')} — RinLit`} description={__('gallery.manageDesc')}>
  <section class="gallery-admin-page">
    <div class="gallery-admin-topbar">
      <a class="gallery-admin-brand" href={`/${lang}/gallery`} aria-label="Gallery">
        <img class="gallery-admin-brand__img gallery-admin-brand__img--light" src="/images/logo/Type=Horizontal, Mode=Light, Monochrome=False.png" alt="RinLit" />
        <img class="gallery-admin-brand__img gallery-admin-brand__img--dark" src="/images/logo/Type=Horizontal, Mode=Dark, Monochrome=False.png" alt="RinLit" />
        <span>{__('gallery.managePage')}</span>
      </a>
      <Button href={`/${lang}/gallery/submit`} primary flat>{__('gallery.newSubmission')}</Button>
    </div>

    <main class="gallery-admin-main" id="gallery-manage-main" hidden>
      <aside class="gallery-admin-sidebar" aria-label={__('gallery.manageNav')}>
        <div class="gallery-admin-identity">
          <strong id="gallery-manage-name">RinLit</strong>
          <span id="gallery-manage-email">...</span>
        </div>
        <NavigationBar
          className="gallery-admin-nav"
          itemClassName="gallery-admin-nav__item"
          items={[
            { key: 'submit', label: __('gallery.newSubmission'), kind: 'link', href: `/${lang}/gallery/submit` },
            { key: 'manage', label: __('gallery.manageSubmissions'), kind: 'link', href: `/${lang}/gallery/manage`, active: true },
            { key: 'review', label: __('gallery.masterReview'), kind: 'link', href: `/${lang}/gallery/review`, hidden: true, attrs: { 'data-review-nav': 'true' } },
          ]}
        />
      </aside>

      <section class="gallery-admin-content">
        <h1 class="panel-title">{__('gallery.manageSubmissions')}</h1>

        <SettingsCard>
          <div class="card-head">
            <div class="card-icon" set:html={icons.list}></div>
            <div class="card-copy">
              <h2>{__('gallery.mySubmissions')}</h2>
              <p>{__('gallery.mySubmissionsDesc')}</p>
            </div>
          </div>

          <dl class="submission-stats" aria-label={__('gallery.submissionOverview')}>
            <div class="submission-stat-item">
              <dt>{__('gallery.total')}</dt>
              <dd id="gallery-stat-total">0</dd>
            </div>
            <div class="submission-stat-item">
              <dt>{__('gallery.published')}</dt>
              <dd id="gallery-stat-published">0</dd>
            </div>
            <div class="submission-stat-item">
              <dt>{__('gallery.pending')}</dt>
              <dd id="gallery-stat-pending">0</dd>
            </div>
            <div class="submission-stat-item">
              <dt>{__('gallery.removing')}</dt>
              <dd id="gallery-stat-removal">0</dd>
            </div>
          </dl>

        <ModerationToolbar
          containerClass="submission-toolbar"
          filterGroupLabel={__('gallery.submissionFilters')}
          layoutGroupLabel={__('gallery.submissionListLayout')}
          filterItems={[
            { key: 'ALL', label: __('gallery.all') },
            { key: 'PUBLISHED', label: __('gallery.published') },
            { key: 'PENDING', label: __('gallery.pending') },
          ]}
          viewItems={[
            { key: 'list', label: __('gallery.listLayout'), icon: icons.list },
            { key: 'grid', label: __('gallery.gridLayout'), icon: icons.grid },
          ]}
          activeFilter="ALL"
          activeView="list"
          filterAttrName="data-submission-filter"
          viewAttrName="data-submission-view"
        />

          <div class="submission-list moderation-list" id="gallery-submission-list" data-view="list" data-filter="ALL"></div>
          <p class="submission-empty" id="gallery-submission-empty" hidden>{__('gallery.noSubmissions')}</p>
          <template id="gallery-submission-template">
            <SettingsCard class="moderation-item submission-item moderation-item--plain" id="gallery-submission-template-card">
              <div class="moderation-item__main">
                <figure class="moderation-item__figure">
                  <img class="moderation-item__image" data-submission-image alt="" loading="lazy" />
                </figure>
                <div class="moderation-item__content">
                  <div class="moderation-item__topline">
                    <span class="moderation-item__type submission-item__status" data-submission-status></span>
                    <time class="moderation-item__time" data-submission-time></time>
                  </div>
                  <h2 class="moderation-item__title" data-submission-title></h2>
                  <p class="moderation-item__description" data-submission-description hidden></p>
                  <ul class="gallery-card__tags moderation-item__tags" data-submission-tags aria-label="Tags" hidden></ul>
                  <form class="removal-form" data-removal-form>
                    <Textarea name="reason" rows={2} placeholder={__('gallery.removalReason')} flat class="removal-textarea" />
                    <div class="removal-actions">
                      <p class="form-message" data-message></p>
                      <Button flat class="removal-action">
                        <span data-removal-label>{__('gallery.requestRemoval')}</span>
                        <span class="btn-spinner" data-removal-spinner hidden>
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                          </svg>
                        </span>
                      </Button>
                    </div>
                  </form>
                </div>
              </div>
            </SettingsCard>
          </template>
        </SettingsCard>
      </section>
    </main>

    <section class="gallery-admin-state" id="gallery-manage-gate">
      <span>{__('gallery.loadingSubmissions')}</span>
    </section>
  </section>
</BaseLayout>

<script is:inline define:vars={{
  __GALLERY_MANAGE_I18N: JSON.stringify({
    defaultError: __('gallery.manage.error'),
    removalSent: __('gallery.manage.removalSent'),
    sendRemoval: __('gallery.manage.sendRemoval'),
    sending: __('gallery.manage.sending'),
    pendingRemoval: __('gallery.manage.pendingRemoval'),
    pendingSubmission: __('gallery.manage.pendingSubmission'),
    noFilteredSubmissions: __('gallery.manage.noFilteredSubmissions'),
    statusPublished: __('gallery.statusPublished'),
    statusPending: __('gallery.statusPending'),
    noSubmissions: __('gallery.noSubmissions'),
    masterReview: __('gallery.masterReview'),
  })
}}>
  window.__GALLERY_MANAGE_I18N = JSON.parse(__GALLERY_MANAGE_I18N);
</script>

<script>
  import { getUser, getUserProfileRole, onAuthStateChange } from '../../../lib/auth.client';
  import { fetchMyGalleryItems, requestGalleryItemRemoval } from '../../../lib/gallery.client';
  import type { GalleryItemModerationRequestStatus, GalleryItemModerationRequestType, GalleryItemStatus } from '../../../lib/database.types';

  const text = (window as any).__GALLERY_MANAGE_I18N || {};
  let currentUser: any = null;
  let cleanupGalleryManage: (() => void) | null = null;

  type RequestRow = { id: string; status: GalleryItemModerationRequestStatus; request_type: GalleryItemModerationRequestType; reason: string | null; created_at: string; decided_at: string | null };
  type TagRelation = { gallery_tags?: { id: string; name: string } | { id: string; name: string }[] | null };
  type ItemRow = {
    id: string;
    title: string | null;
    description: string | null;
    image_url: string;
    created_at: string | null;
    status: GalleryItemStatus;
    gallery_item_tags?: TagRelation[] | null;
    gallery_item_moderation_requests?: RequestRow[] | null;
  };

  function showLoginRequired() {
    const next = encodeURIComponent(window.location.pathname + window.location.search);
    window.location.replace(`/${document.documentElement.lang}/account/redirect?next=${next}`);
  }

  function getDisplayName(user: any) {
    return user?.user_metadata?.display_name || user?.user_metadata?.full_name || user?.email?.split('@')[0] || 'RinLit';
  }

  function escapeHtml(value: string) {
    return value.replace(/[&<>'"]/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      "'": '&#39;',
      '"': '&quot;',
    })[char] || char);
  }

  function extractTags(row: ItemRow) {
    return (row.gallery_item_tags || [])
      .flatMap((relation) => relation.gallery_tags || [])
      .filter(Boolean);
  }

  function hasPendingRemoval(row: ItemRow) {
    return (row.gallery_item_moderation_requests || []).some((request) => request.request_type === 'REMOVAL' && request.status === 'PENDING');
  }

  function hasPendingSubmission(row: ItemRow) {
    return (row.gallery_item_moderation_requests || []).some((request) => request.request_type === 'SUBMISSION' && request.status === 'PENDING');
  }

  function getStatusLabel(status: GalleryItemStatus) {
    if (status === 'PUBLISHED') return text.statusPublished;
    return text.statusPending;
  }

  function formatCompactDate(value: string | null | undefined) {
    if (!value) return '';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '';
    return new Intl.DateTimeFormat(document.documentElement.lang, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }).format(date);
  }

  function renderSubmission(row: ItemRow) {
    const template = document.getElementById('gallery-submission-template') as HTMLTemplateElement | null;
    if (!template) return null;

    const tags = extractTags(row);
    const pendingRemoval = hasPendingRemoval(row);
    const pendingSubmission = hasPendingSubmission(row);
    const canRemove = row.status === 'PUBLISHED' && !pendingRemoval;
    const fragment = template.content.cloneNode(true) as DocumentFragment;
    const card = fragment.querySelector('.submission-item') as HTMLElement | null;
    const image = fragment.querySelector('[data-submission-image]') as HTMLImageElement | null;
    const status = fragment.querySelector('[data-submission-status]') as HTMLElement | null;
    const time = fragment.querySelector('[data-submission-time]') as HTMLTimeElement | null;
    const title = fragment.querySelector('[data-submission-title]') as HTMLElement | null;
    const description = fragment.querySelector('[data-submission-description]') as HTMLElement | null;
    const tagsList = fragment.querySelector('[data-submission-tags]') as HTMLElement | null;
    const form = fragment.querySelector('[data-removal-form]') as HTMLFormElement | null;
    const textarea = fragment.querySelector('textarea') as HTMLTextAreaElement | null;
    const button = fragment.querySelector('[data-removal-label]')?.closest('button') as HTMLButtonElement | null;
    const label = fragment.querySelector('[data-removal-label]') as HTMLElement | null;
    const spinner = fragment.querySelector('[data-removal-spinner]') as HTMLElement | null;
    if (!card || !image || !status || !time || !title || !description || !tagsList || !form || !textarea || !button || !label || !spinner) return null;

    const disabledLabel = pendingRemoval ? text.pendingRemoval : pendingSubmission ? text.pendingSubmission : text.sendRemoval;

    card.removeAttribute('id');
    card.setAttribute('data-gallery-item-id', row.id);
    card.setAttribute('data-status', row.status);
    form.setAttribute('data-removal-form', row.id);
    image.src = row.image_url;
    image.alt = row.title || 'Gallery image';
    status.textContent = getStatusLabel(row.status);
    status.setAttribute('data-status', row.status);
    time.dateTime = row.created_at || '';
    time.textContent = formatCompactDate(row.created_at);
    title.textContent = row.title || 'Untitled';
    description.textContent = row.description || '';
    description.hidden = !row.description;
    label.textContent = disabledLabel;
    spinner.hidden = true;
    textarea.disabled = !canRemove;
    button.disabled = !canRemove;
    button.closest('.removal-action')?.classList.toggle('is-disabled', !canRemove);

    tagsList.innerHTML = '';
    tagsList.hidden = tags.length === 0;
    tags.forEach((tag: any) => {
      const li = document.createElement('li');
      li.textContent = tag.name;
      tagsList.append(li);
    });

    return fragment;
  }

  function updateSubmissionStats(rows: ItemRow[]) {
    const total = document.getElementById('gallery-stat-total');
    const published = document.getElementById('gallery-stat-published');
    const pending = document.getElementById('gallery-stat-pending');
    const removal = document.getElementById('gallery-stat-removal');
    if (!total || !published || !pending || !removal) return;

    total.textContent = String(rows.length);
    published.textContent = String(rows.filter((row) => row.status === 'PUBLISHED').length);
    pending.textContent = String(rows.filter((row) => row.status === 'PENDING').length);
    removal.textContent = String(rows.filter(hasPendingRemoval).length);
  }

  function applySubmissionView(list: HTMLElement, empty: HTMLElement) {
    const filter = list.getAttribute('data-filter') || 'ALL';
    const items = Array.from(list.querySelectorAll('[data-gallery-item-id]')) as HTMLElement[];
    let visibleCount = 0;

    items.forEach((item) => {
      const matches = filter === 'ALL' || item.getAttribute('data-status') === filter;
      item.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    empty.textContent = items.length === 0 ? text.noSubmissions : text.noFilteredSubmissions;
    empty.hidden = visibleCount > 0;
  }

  async function initGalleryManagePage() {
    cleanupGalleryManage?.();

    const main = document.getElementById('gallery-manage-main');
    const gate = document.getElementById('gallery-manage-gate');
    const name = document.getElementById('gallery-manage-name');
    const email = document.getElementById('gallery-manage-email');
    const list = document.getElementById('gallery-submission-list');
    const empty = document.getElementById('gallery-submission-empty');
    const submissionFilterButtons = Array.from(document.querySelectorAll('[data-submission-filter]')) as HTMLButtonElement[];
    const submissionViewButtons = Array.from(document.querySelectorAll('[data-submission-view]')) as HTMLButtonElement[];
    if (!main || !gate || !name || !email || !list || !empty) return;

    const { user, error } = await getUser();
    if (error || !user) {
      showLoginRequired();
      return;
    }

    const { data: profile } = await getUserProfileRole(user.id);

    const reviewNav = document.querySelector('[data-review-nav]') as HTMLElement | null;
    if (reviewNav) reviewNav.hidden = profile?.role !== 'master';

    currentUser = user;
    name.textContent = getDisplayName(user);
    email.textContent = user.email || '';
    gate.hidden = true;
    main.hidden = false;

    const result = await fetchMyGalleryItems(user.id);
    if (result.error) {
      gate.textContent = result.error.message || text.defaultError;
      gate.hidden = false;
      return;
    }

    const rows = ((result.data || []) as unknown as ItemRow[]).filter((row) => row.status !== 'HIDDEN');
    updateSubmissionStats(rows);
    list.innerHTML = '';
    rows.forEach((row) => {
      const node = renderSubmission(row);
      if (node) list.append(node);
    });
    applySubmissionView(list, empty);

    const disposers: Array<() => void> = [];
    const unsubscribeAuth = onAuthStateChange((event) => {
      if (event === 'SIGNED_OUT') showLoginRequired();
    });
    disposers.push(unsubscribeAuth);

    const onSubmissionFilterClick = (event: Event) => {
      const button = (event.currentTarget || event.target) as HTMLButtonElement;
      const filter = button.getAttribute('data-submission-filter') || 'ALL';
      list.setAttribute('data-filter', filter);
      submissionFilterButtons.forEach((item) => item.classList.toggle('is-active', item === button));
      applySubmissionView(list, empty);
    };

    const onSubmissionViewClick = (event: Event) => {
      const button = (event.currentTarget || event.target) as HTMLButtonElement;
      const view = button.getAttribute('data-submission-view') || 'list';
      list.setAttribute('data-view', view);
      submissionViewButtons.forEach((item) => item.classList.toggle('is-active', item === button));
    };

    submissionFilterButtons.forEach((button) => {
      button.addEventListener('click', onSubmissionFilterClick);
      disposers.push(() => button.removeEventListener('click', onSubmissionFilterClick));
    });

    submissionViewButtons.forEach((button) => {
      button.addEventListener('click', onSubmissionViewClick);
      disposers.push(() => button.removeEventListener('click', onSubmissionViewClick));
    });

    const forms = Array.from(list.querySelectorAll('[data-removal-form]')) as HTMLFormElement[];
    const onSubmit = async (event: Event) => {
      event.preventDefault();
      const form = event.currentTarget as HTMLFormElement;
      const galleryItemId = form.getAttribute('data-removal-form') || '';
      const textarea = form.querySelector('textarea') as HTMLTextAreaElement | null;
      const button = form.querySelector('button') as HTMLButtonElement | null;
      const label = form.querySelector('[data-removal-label]') as HTMLElement | null;
      const spinner = form.querySelector('[data-removal-spinner]') as HTMLElement | null;
      const message = form.querySelector('[data-message]') as HTMLElement | null;
      if (!galleryItemId || !textarea || !button || !label || !spinner || !message || !currentUser) return;

      button.disabled = true;
      button.closest('.removal-action')?.classList.add('is-disabled');
      label.hidden = true;
      spinner.hidden = false;
      message.textContent = '';
      message.setAttribute('data-type', 'neutral');

      try {
        await requestGalleryItemRemoval({ userId: currentUser.id, galleryItemId, reason: textarea.value });
        message.textContent = text.removalSent;
        message.setAttribute('data-type', 'success');
        label.textContent = text.pendingRemoval;
        label.hidden = false;
        spinner.hidden = true;
        textarea.disabled = true;
      } catch (error: any) {
        message.textContent = error?.message || text.defaultError;
        message.setAttribute('data-type', 'error');
        button.disabled = false;
        button.closest('.removal-action')?.classList.remove('is-disabled');
        label.textContent = text.sendRemoval;
        label.hidden = false;
        spinner.hidden = true;
      }
    };

    forms.forEach((form) => {
      form.addEventListener('submit', onSubmit);
      disposers.push(() => form.removeEventListener('submit', onSubmit));
    });

    cleanupGalleryManage = () => disposers.forEach((dispose) => dispose());
  }

  document.addEventListener('astro:before-swap', () => {
    cleanupGalleryManage?.();
    cleanupGalleryManage = null;
  });
  document.addEventListener('astro:page-load', initGalleryManagePage);
  initGalleryManagePage();
</script>

<style>
  .gallery-admin-page {
    min-height: 100vh;
    padding: 104px clamp(20px, 4vw, 48px) 80px;
    background: var(--bg);
  }

  .gallery-admin-topbar {
    max-width: 1400px;
    margin: 0 auto 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    padding-bottom: 16px;
    gap: 18px;
  }

  .gallery-admin-brand {
    display: inline-flex;
    align-items: center;
    gap: 0;
    color: var(--text-strong);
    text-decoration: none;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: 0;
  }

  .gallery-admin-brand__img {
    width: auto;
    height: 42px;
    display: block;
  }

  .gallery-admin-brand__img--light { display: var(--logo-light-display); }
  .gallery-admin-brand__img--dark { display: var(--logo-dark-display); }

  .gallery-admin-topbar :global(.pill),
  .gallery-admin-topbar :global(.btn) {
    width: auto;
  }

  .gallery-admin-topbar :global(.btn) {
    height: 36px;
    padding: 0 18px;
    font-size: 14px;
  }

  .gallery-admin-main {
    display: grid;
    grid-template-columns: 240px minmax(0, 800px);
    justify-content: center;
    gap: clamp(48px, 7vw, 80px);
    max-width: 1400px;
    margin: 0 auto;
  }

  .gallery-admin-identity {
    display: grid;
    gap: 5px;
    margin-bottom: 34px;
  }

  .gallery-admin-identity strong {
    font-size: 18px;
    font-weight: 800;
    color: var(--text-strong);
  }

  .gallery-admin-identity span {
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .gallery-admin-content {
    min-width: 0;
    display: grid;
    gap: 16px;
  }

  .panel-title {
    margin: 0 0 6px;
    color: var(--text-strong);
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: 0;
    font-weight: 800;
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .card-copy {
    min-width: 0;
    flex: 1;
  }

  .card-icon {
    width: 42px;
    height: 42px;
    flex: 0 0 42px;
    display: grid;
    place-items: center;
    border-radius: 8px;
    color: var(--color-primary-600);
    background: color-mix(in srgb, var(--surface) 88%, var(--color-primary-500));
  }

  :root.dark .card-icon {
    color: var(--color-primary-300);
    background: color-mix(in srgb, var(--surface) 92%, black);
  }

  :global(.card-icon svg) {
    width: 24px;
    height: 24px;
    display: block;
  }

  .card-head h2 {
    display: block;
    margin: 0;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0;
    color: var(--text-strong);
  }

  .card-head p {
    display: block;
    margin: 4px 0 0;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 600;
    line-height: 1.45;
    text-wrap: pretty;
  }

  .submission-stats {
    display: grid;
    gap: 0;
    margin: 18px 0 0;
  }

  .submission-stat-item {
    display: grid;
    grid-template-columns: minmax(88px, 0.32fr) minmax(0, 1fr);
    gap: 16px;
    align-items: center;
    padding: 10px 0;
    border-top: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
  }

  .submission-stat-item:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .submission-stat-item dt {
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.4;
  }

  .submission-stat-item dd {
    margin: 0;
    color: var(--text-strong);
    font-size: 15px;
    font-weight: 850;
    line-height: 1.2;
  }

  .submission-list,
  .moderation-list {
    display: grid;
    gap: 10px;
    margin-top: 16px;
  }

  .submission-list[data-view='grid'],
  .moderation-list[data-view='grid'] {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .submission-item {
    display: grid;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
  }

  .submission-item:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .moderation-item {
    display: grid;
    gap: 8px;
    padding: 10px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--surface) 88%, var(--color-primary-100));
    transition: opacity 220ms ease, transform 220ms ease;
  }

  :root.dark .moderation-item {
    background: color-mix(in srgb, var(--surface) 90%, black);
  }

  :global(.moderation-item--plain.settings-card) {
    border-radius: 14px;
  }

  :global(.moderation-item--plain.settings-card:not(.settings-card--row)) {
    padding: 10px;
  }

  :global(.moderation-item--plain.settings-card > .settings-card__bg-layer) {
