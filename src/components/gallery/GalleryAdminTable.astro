---
interface Column {
  label: string;
  class?: string;
  width?: string;
}

interface Props {
  id: string;
  class?: string;
  columns: Column[];
  view?: string;
  filter?: string;
}

const { id, class: className = '', columns, view = 'list', filter = 'ALL' } = Astro.props;
---

<div class={`gallery-admin-table ${className}`.trim()} data-view={view}>
  <table>
    <colgroup>
      {columns.map((column) => <col style={column.width ? `width: ${column.width}` : undefined} />)}
    </colgroup>
    <thead>
      <tr>
        {columns.map((column) => <th class={column.class} scope="col">{column.label}</th>)}
      </tr>
    </thead>
    <tbody id={id} data-view={view} data-filter={filter}>
      <slot />
    </tbody>
  </table>
</div>

<style>
  .gallery-admin-table {
    margin-top: 16px;
    overflow: hidden;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--border) 68%, transparent);
    background: color-mix(in srgb, var(--surface) 82%, transparent);
  }

  :root.dark .gallery-admin-table {
    background: color-mix(in srgb, var(--surface) 88%, black);
  }

  .gallery-admin-table table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .gallery-admin-table th {
    padding: 12px 14px;
    text-align: left;
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 850;
    line-height: 1.2;
    letter-spacing: 0.01em;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 62%, transparent);
  }

  .gallery-admin-table :global(td) {
    padding: 10px 14px;
    vertical-align: middle;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 48%, transparent);
  }

  .gallery-admin-table :global(tr:last-child td) {
    border-bottom: 0;
  }

  .gallery-admin-table :global(tbody tr) {
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    transition: opacity 220ms ease, transform 220ms ease, background-color 160ms ease;
  }

  .gallery-admin-table :global(tbody tr:nth-child(even)) {
    background: color-mix(in srgb, var(--surface) 84%, var(--color-primary-100));
  }

  :root.dark .gallery-admin-table :global(tbody tr) {
    background: color-mix(in srgb, var(--surface) 92%, black);
  }

  :root.dark .gallery-admin-table :global(tbody tr:nth-child(even)) {
    background: color-mix(in srgb, var(--surface) 84%, black);
  }

  .gallery-admin-table :global(.gallery-admin-table__media) {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .gallery-admin-table :global(.gallery-admin-table__figure) {
    position: relative;
    width: 52px;
    flex: 0 0 52px;
    aspect-ratio: 1;
    margin: 0;
    border-radius: 12px;
    overflow: hidden;
    background: color-mix(in srgb, var(--surface) 72%, var(--color-primary-100));
  }

  .gallery-admin-table :global(.gallery-admin-table__image) {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-admin-table :global(.gallery-admin-table__meta),
  .gallery-admin-table :global(.gallery-admin-table__cell) {
    min-width: 0;
    overflow: hidden;
  }

  .gallery-admin-table :global(.gallery-admin-table__title) {
    margin: 0;
    color: var(--text-strong);
    font-size: 14px;
    font-weight: 900;
    line-height: 1.3;
    letter-spacing: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gallery-admin-table :global(.gallery-admin-table__description),
  .gallery-admin-table :global(.gallery-admin-table__reason span) {
    margin: 0;
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 650;
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gallery-admin-table :global(.gallery-admin-table__badge) {
    width: max-content;
    max-width: 100%;
    border-radius: 999px;
    padding: 4px 9px;
    color: #ffffff;
    background: var(--color-primary-600);
    font-size: 12px;
    line-height: 1.1;
    font-weight: 900;
    overflow-wrap: anywhere;
  }

  .gallery-admin-table :global(.gallery-admin-table__time) {
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 750;
  }

  .gallery-admin-table :global(.gallery-admin-table__tags) {
    display: none !important;
  }

  .gallery-admin-table :global(.gallery-admin-table__row.is-resolved) {
    opacity: 0;
    transform: translateY(-6px);
  }

  @media (max-width: 960px) {
    .gallery-admin-table thead {
      display: none;
    }

    .gallery-admin-table table,
    .gallery-admin-table tbody,
    .gallery-admin-table tr,
    .gallery-admin-table td {
      display: block;
    }

    .gallery-admin-table tbody {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1px;
      background: color-mix(in srgb, var(--border) 48%, transparent);
    }

    .gallery-admin-table :global(td) {
      border-bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .gallery-admin-table {
      border-radius: 14px;
    }

    .gallery-admin-table :global(td) {
      padding: 12px;
    }

    .gallery-admin-table :global(.gallery-admin-table__figure) {
      width: 46px;
      flex-basis: 46px;
    }
  }
</style>
