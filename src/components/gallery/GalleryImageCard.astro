---
import Button from '../Button.astro';
import Pill from '../Pill.astro';

interface TagLike {
  name: string;
}

interface Props {
  item: {
    id: string;
    title: string | null;
    description: string | null;
    image_url: string;
    width?: number | null;
    height?: number | null;
    created_at?: string | null;
    status?: string;
    tags?: TagLike[];
    favorite_count?: number | null;
    favoriteCount?: number | null;
  };
  compact?: boolean;
}

const { item, compact = false } = Astro.props;
const tags = item.tags || [];
const favoriteCount = item.favorite_count ?? item.favoriteCount ?? 0;
const aspectRatio = item.width && item.height ? `${item.width} / ${item.height}` : undefined;
---

<Pill panel flat class={`gallery-card-shell ${compact ? 'gallery-card-shell--compact' : ''}`}>
  <article class:list={["gallery-card", { "gallery-card--compact": compact }]} data-gallery-item-id={item.id} style={aspectRatio ? { aspectRatio } : undefined} draggable="false">
    <img class="gallery-card__image" src={item.image_url} alt={item.title || 'Gallery image'} loading="lazy" draggable="false" />
    <div class="gallery-card__text-blur" aria-hidden="true"></div>
    <div class="gallery-card__text-scrim" aria-hidden="true"></div>
    <div class="gallery-card__favorite">
      <Button
        icon="heart"
        flat
        class="gallery-card__favorite-button"
        type="button"
        data-gallery-favorite={item.id}
        data-gallery-favorite-count={favoriteCount}
        aria-pressed="false"
        aria-label="收藏"
        title="收藏"
      >
        <span class="gallery-card__favorite-count" data-count={favoriteCount}>{favoriteCount}</span>
      </Button>
    </div>
    <div class="gallery-card__body">
      {tags.length > 0 && (
        <ul class="gallery-card__tags" aria-label="Tags">
          {tags.map((tag) => <li><span aria-hidden="true">#</span>{tag.name}</li>)}
        </ul>
      )}
      <div class="gallery-card__head">
        <h2>{item.title || 'Untitled'}</h2>
      </div>
      {item.description && <p>{item.description}</p>}
    </div>
  </article>
</Pill>

<style>
  :global(.gallery-card-shell) {
    display: block;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    break-inside: avoid;
    margin: 0 0 18px;
    border-radius: 24px;
    --pill-radius: 24px;
    --pill-press-scale: 1.02;
    --pill-drag-scale: 0.02;
    -webkit-user-drag: none;
    user-drag: none;
  }

  :global(.gallery-card-shell > .pill__bg-layer) {
    background: transparent;
  }

  .gallery-card {
    position: relative;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    min-height: 160px;
    overflow: hidden;
    border-radius: inherit;
    isolation: isolate;
    background: color-mix(in srgb, var(--surface) 72%, var(--color-primary-100));
    box-shadow:
      0 18px 36px color-mix(in srgb, var(--shadow-color) 18%, transparent),
      inset 0 1px 0 color-mix(in srgb, #ffffff 42%, transparent);
  }

  .gallery-card__image {
    display: block;
    width: 100%;
    max-width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    transition: transform 360ms cubic-bezier(0.22, 1, 0.36, 1), filter 360ms ease;
  }

  .gallery-card__text-scrim,
  .gallery-card__text-blur {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    pointer-events: none;
  }

  .gallery-card__text-scrim {
    height: clamp(120px, 38%, 220px);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, #374151 0%, transparent) 0%,
      color-mix(in srgb, #424750 28%, transparent) 28%,
      color-mix(in srgb, #2b2f35 72%, transparent) 100%
    );
  }

  .gallery-card__text-blur {
    height: clamp(130px, 44%, 240px);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 0, 0, 0.50) 28%,
      #000000 100%
    );
    -webkit-mask-image: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 0, 0, 0.9) 28%,
      #000000 100%
    );
  }

  .gallery-card__favorite {
    position: absolute;
    top: 24px;
    right: 24px;
    z-index: 4;
    --pill-radius: 999px;
  }

  .gallery-card__favorite :global(.pill) {
    --pill-press-scale: 1.04;
  }

  .gallery-card__favorite :global(.btn) {
    min-width: 40px;
    width: auto;
    height: 40px;
    padding: 0 14px;
    gap: 6px;
    color: var(--text-strong);
    font-size: 14px;
  }

  .gallery-card__favorite :global(.btn--icon-only) {
    width: 40px;
    padding: 0;
  }

  .gallery-card__favorite :global(.btn__text) {
    flex: 0 0 auto;
  }

  .gallery-card__favorite-count {
    display: block;
    min-width: 0;
    font-size: 14px;
    font-weight: 800;
    line-height: 1;
  }

  .gallery-card__favorite-count[data-count="0"] {
    display: none;
  }

  .gallery-card__favorite :global(.btn.is-favorite) {
    color: var(--color-primary-600);
  }

  .gallery-card__favorite :global(.btn:disabled) {
    opacity: 0.55;
    cursor: default;
  }

  .gallery-card__favorite :global(.btn.is-shaking) {
    animation: gallery-fav-shake 0.28s ease;
  }

  @keyframes gallery-fav-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  .gallery-card__favorite :global(.btn[data-error])::after {
    content: attr(data-error);
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    padding: 4px 10px;
    border-radius: 8px;
    background: #dc2626;
    color: #fff;
    font-size: 12px;
    font-weight: 700;
  }

  .gallery-card__body {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    display: grid;
    gap: 6px;
    padding: 24px;
    color: #ffffff;
  }

  .gallery-card__head {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 12px;
    min-width: 0;
  }

  .gallery-card h2,
  .gallery-card p,
  .gallery-card__tags li {
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
    transition: max-height 260ms cubic-bezier(0.22, 1, 0.36, 1), color 180ms ease, background 180ms ease;
  }

  .gallery-card h2 {
    margin: 0;
    min-width: 0;
    color: #ffffff;
    font-size: 24px;
    line-height: 1.18;
    font-weight: 900;
    letter-spacing: 0;
    text-wrap: pretty;
  }

  .gallery-card p {
    margin: 0;
    color: color-mix(in srgb, #ffffff 82%, transparent);
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    text-wrap: pretty;
  }

  .gallery-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    min-width: 0;
    max-height: 28px;
    margin: 0;
    padding: 0;
    overflow: hidden;
    list-style: none;
    transition: max-height 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .gallery-card__tags li,
  .gallery-card__status {
    min-width: 0;
    border-radius: 999px;
    color: color-mix(in srgb, #ffffff 88%, transparent);
    font-size: 14px;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  .gallery-card__tags li {
    max-width: 100%;
    padding: 4px 7px;
    font-weight: 700;
    background: transparent;
  }

  .gallery-card__tags li span {
    margin-right: 4px;
    color: color-mix(in srgb, #ffffff 64%, transparent);
    font-size: 14px;
  }

  .gallery-card__status {
    flex: 0 0 auto;
    padding: 4px 9px;
    background: color-mix(in srgb, #ffffff 14%, transparent);
    font-weight: 800;
    text-transform: lowercase;
  }

  .gallery-card--compact {
    min-height: 180px;
    margin: 0;
  }

  .gallery-card--compact .gallery-card__body {
    padding: 18px;
  }

  @media (hover: hover) and (pointer: fine) {
    .gallery-card:hover .gallery-card__image {
      transform: scale(1.01);
      filter: saturate(1.2);
    }

    .gallery-card:hover h2,
    .gallery-card:hover p,
    .gallery-card:hover .gallery-card__tags li {
      display: block;
      -webkit-line-clamp: unset;
      overflow: visible;
    }

    .gallery-card:hover .gallery-card__tags {
      max-height: 160px;
    }

    .gallery-card__tags li:hover {
      background: color-mix(in srgb, #ffffff 16%, transparent);
    }
  }

  @media (max-width: 560px) {
    :global(.gallery-card-shell) {
      margin-bottom: 14px;
      border-radius: 18px;
      --pill-radius: 18px;
    }

    .gallery-card {
      min-height: clamp(176px, 54vw, 260px);
    }

    .gallery-card__image {
      height: auto;
      min-height: inherit;
      object-fit: cover;
    }

    .gallery-card__favorite {
      top: 10px;
      right: 10px;
    }

    .gallery-card__favorite :global(.btn) {
      min-width: 32px;
      height: 32px;
      padding: 0 9px;
      gap: 4px;
      font-size: 12px;
    }

    .gallery-card__favorite :global(.btn--icon-only) {
      width: 32px;
      padding: 0;
    }

    .gallery-card__favorite :global(.btn__icon),
    .gallery-card__favorite :global(.btn__icon svg) {
      width: 16px;
      height: 16px;
    }

    .gallery-card__favorite-count {
      font-size: 12px;
    }

    .gallery-card__body {
      gap: 5px;
      padding: 48px 12px 12px;
    }

    .gallery-card__tags {
      gap: 4px;
      max-height: 22px;
    }

    .gallery-card__tags li {
      padding: 2px 5px;
      font-size: 12px;
      line-height: 1.25;
    }

    .gallery-card__tags li span {
      margin-right: 2px;
      font-size: 12px;
    }

    .gallery-card h2 {
      font-size: 18px;
      line-height: 1.12;
    }

    .gallery-card p {
      font-size: 12px;
      line-height: 1.3;
    }
  }
</style>

<script is:inline>
  (function () {
    var breakpoint = 560;
    function updateDrag() {
      var cards = document.querySelectorAll('.gallery-card-shell');
      var isMobile = window.innerWidth <= breakpoint;
      for (var i = 0; i < cards.length; i++) {
        if (isMobile) {
          cards[i].setAttribute('data-no-drag', '');
        } else {
          cards[i].removeAttribute('data-no-drag');
        }
      }
    }
    updateDrag();
    window.addEventListener('resize', updateDrag);
    document.addEventListener('astro:page-load', updateDrag);
  })();
</script>
