---
import { t, locales as allLocales } from '../../i18n/index';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getIcon } from '../../utils/icons';
import Link from '../Link.astro';
import Pill from '../Pill.astro';
import NavButton from '../NavButton.astro';
import Button from '../Button.astro';
import Menu from '../Menu.astro';
import MenuItem from '../MenuItem.astro';

interface Props {
  lang?: string;
  currentPath?: string;
}

const { lang: currentLang, currentPath = '/' } = Astro.props;
const __ = (key: string) => t(currentLang, key);

const navItems = [
  { label: __('nav.fields'),  href: 'fields',   icon: 'map' },
  { label: __('nav.gallery'), href: 'gallery',  icon: 'photo' },
  { label: __('nav.writing'), href: 'writing',  icon: 'pencil' },
  { label: __('nav.me'),      href: 'me',       icon: 'badge' },
];

// 计算无语言前缀的路径用于激活状态判断
const stripLangPrefix = (path: string) => {
  const langPattern = new RegExp(`^/(${allLocales.join('|')})(/|$)`);
  return path.replace(langPattern, '/');
};

const cleanPath = stripLangPrefix(currentPath);
const isActive = (href: string) => {
  if (href === '/') return cleanPath === '/';
  return cleanPath.startsWith(`/${href}`);
};
---

<div class="nav-header-mask nav-header-mask--top" aria-hidden="true"></div>
<div class="nav-header-mask nav-header-mask--bottom" aria-hidden="true"></div>
<header class="nav-header">
  <!-- Logo pill -->
  <Pill class="nav-pill nav-pill--logo-group">
    <NavButton
      icon="chevron-left"
      href="javascript:history.back()"
      class="back-btn back-btn--desktop"
      id="back-btn-desktop"
      aria-label="返回"
    />
    <span class="nav-pill__separator"></span>
    <Link to="" class="nav-pill__logo-link" aria-label="RinLit Home">
      <img
        class="nav-pill__logo-img nav-pill__logo--light"
        src="/images/logo/Type=Square, Mode=Light, Monochrome=False.png"
        alt="RinLit"
      />
      <img
        class="nav-pill__logo-img nav-pill__logo--dark"
        src="/images/logo/Type=Square, Mode=Dark, Monochrome=False.png"
        alt="RinLit"
      />
    </Link>
  </Pill>

  <!-- Nav pill -->
  <Pill class="nav-pill nav-pill--nav">
    {navItems.map((item) => (
      <NavButton
        href={getRelativeLocaleUrl(currentLang, item.href)}
        active={isActive(item.href)}
        icon={item.icon}
      >
        {item.label}
      </NavButton>
    ))}
  </Pill>

  <!-- Top bar -->
  <div class="top-bar">
    <Button icon="chevron-left" class="back-btn back-btn--mobile" id="back-btn-mobile" aria-label="返回" />
    <div class="toolbar" aria-label="工具栏">
        <!-- 用户按钮 -->
        <div class="user-area">
          <span data-action="auth:open" data-auth-tab="signin">
          <Button
            id="auth-btn-signin"
            icon="user"
            class="auth-btn"
            aria-label={__('auth.signIn')}
          >
            {__('auth.signIn')}
          </Button>
          </span>
          <div class="user-menu" id="user-menu" style="display:none;">
            <Button
              id="auth-btn-user"
              icon="user"
              class="auth-btn is-user-btn"
              aria-label="Account"
            >
              <span id="user-account-display"></span>
            </Button>
            <Menu id="user-menu-dropdown">
              <MenuItem value="gallery">{__('gallery.manage')}</MenuItem>
              <MenuItem value="account">{__('auth.account')}</MenuItem>
              <MenuItem value="signout">{__('auth.signOut')}</MenuItem>
            </Menu>
          </div>
        </div>
        <div class="menu-anchor">
        <Button icon="menu-2" class="menu-trigger" id="menu-trigger" aria-label="Menu" />
        <Menu class="menu-dropdown" id="settings-menu">
          <MenuItem icon="language">
            {__('nav.language')}
            <Menu slot="submenu" submenu type="radio" group="lang">
              <MenuItem value="zh-cn" checked={currentLang === 'zh-cn'}>中文</MenuItem>
              <MenuItem value="en" checked={currentLang === 'en'}>English</MenuItem>
            </Menu>
          </MenuItem>
          <MenuItem icon="sun">
            {__('nav.colorMode')}
            <Menu slot="submenu" submenu type="radio" group="theme">
              <MenuItem value="light" checked>浅色</MenuItem>
              <MenuItem value="dark">深色</MenuItem>
              <MenuItem value="auto">自动</MenuItem>
            </Menu>
          </MenuItem>
        </Menu>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-header {
    position: fixed;
    top: 24px;
    left: 0;
    right: 0;
    z-index: 50;
    max-width: 1448px;  /* 24*2 */
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;
  }

  :global(.nav-pill) {
    flex-shrink: 0;
  }

  :global(.nav-pill--logo-group) {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 46px;
    width: 46px;
    padding: 6px 0;
    gap: 3px;
  }

  @media (min-width: 769px) {
    :global(.nav-pill--logo-group.nav-pill--has-back) {
      width: fit-content;
      padding: 6px 6px;
    }
  }

  .nav-pill__logo-link {
    display: flex;
    flex: 0 0 40px;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    text-decoration: none;
    overflow: hidden;
    -webkit-user-drag: none;
    user-drag: none;
  }

  .nav-pill__logo-img {
    flex: 0 0 auto;
    width: 40px;
    height: 40px;
    display: block;
    object-fit: contain;
    -webkit-user-drag: none;
    user-drag: none;
  }

  .nav-pill__logo--light { display: var(--logo-light-display); }
  .nav-pill__logo--dark { display: var(--logo-dark-display); }

  :global(.nav-pill--nav) {
    display: flex;
    align-items: center;
    gap: 6px;
    height: 46px;
    padding: 6px 7px;
    margin-left: auto;
  }

  @media (max-width: 768px) {
    .nav-header {
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      max-width: none;
      padding: 0 36px 32px 36px;
      gap: 12px;
    }

    :global(.nav-pill) {
      --pill-radius: 9999px;
    }

    :global(.nav-pill--logo-group) {
      width: 72px;
      height: 72px;
      padding: 0;
      justify-content: center;
    }

    .nav-pill__logo-link {
      width: 72px;
      height: 72px;
    }

    .nav-pill__logo-img {
      width: 48px;
      height: 48px;
    }

    :global(.nav-pill--nav) {
      height: 72px;
      padding: 8px 6px;
      gap: 6px;
      justify-content: space-around;
    }
  }

  @supports (-webkit-touch-callout: none) {
    @media (max-width: 768px) {
      .nav-header {
        padding-bottom: calc(32px + 48px);
      }
    }
  }

  @media (max-width: 474px) {
    .nav-header {
      --scale: calc(max(266px, 100vw) / 474px);
      padding: 0 calc(36px * var(--scale)) calc(32px * var(--scale));
      gap: calc(12px * var(--scale));
    }

    :global(.nav-pill--logo-group) {
      width: calc(72px * var(--scale));
      height: calc(72px * var(--scale));
    }

    .nav-pill__logo-link {
      width: calc(72px * var(--scale));
      height: calc(72px * var(--scale));
    }

    .nav-pill__logo-img {
      width: calc(48px * var(--scale));
      height: calc(48px * var(--scale));
    }

    :global(.nav-pill--nav) {
      height: calc(72px * var(--scale));
      padding: calc(8px * var(--scale)) calc(6px * var(--scale));
      gap: calc(6px * var(--scale));
      flex: 1;        /* 核心修改 */
      min-width: 0;
    }
  }

  :global(.back-btn--desktop:not(.is-visible)),
  :global(.back-btn--mobile:not(.is-visible)) {
    display: none !important;
  }

  .nav-pill__separator {
    display: none;
  }

  @media (min-width: 769px) {
    :global(.back-btn--desktop.is-visible) {
      display: flex;
    }
    :global(.back-btn--desktop.is-visible) + .nav-pill__separator {
      display: block;
    }
    :global(.back-btn--mobile) {
      display: none !important;
    }
  }

  @media (max-width: 768px) {
    :global(.back-btn--mobile.is-visible) {
      display: flex;
    }
    :global(.back-btn--desktop),
    :global(.back-btn--desktop.is-visible),
    .nav-pill__separator {
      display: none !important;
    }
  }

  .top-bar {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: 8px;
  }

  .toolbar {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    gap: 8px;
  }

  .menu-anchor {
    position: relative;
  }

  /* ======== 用户区域 ======== */
  .user-area {
    position: relative;
    flex-shrink: 1;
    min-width: 0;
    max-width: min(32vw, 220px);
  }

  .user-area :global(.auth-btn) {
    display: block;
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .user-area :global(.auth-btn .pill) {
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .user-area :global(.auth-btn .btn) {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    padding: 0 16px;
    height: 46px;
    font-size: 15px;
  }

  .user-area :global(.auth-btn.is-user-btn .btn) {
    padding: 0 14px;
    font-size: 14px;
    font-weight: 600;
  }

  #user-account-display {
    display: block;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    flex: 1 1 auto;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* User menu — Menu 组件自带 Pill 背景，此处仅设最小宽度 */
  #user-menu-dropdown {
    min-width: 150px;
  }

  @media (max-width: 1024px) {
    .user-area {
      max-width: min(28vw, 180px);
    }
  }

  @media (max-width: 768px) {
    .user-area {
      max-width: min(42vw, 150px);
    }

    .user-area :global(.auth-btn .btn) {
      height: 46px;
      padding: 0 14px;
      font-size: 14px;
    }
  }

  @media (max-width: 420px) {
    .user-area {
      max-width: min(36vw, 132px);
    }
  }

  /* 顶栏按钮统一高度 */
  .top-bar :global(.btn) {
    height: 46px;
  }

  /* 纯图标按钮在顶栏保持正方形 */
  .top-bar :global(.btn--icon-only) {
    width: 46px;
  }

  @media (max-width: 768px) {
    .top-bar {
      position: fixed;
      top: 20px;
      left: 20px;
      right: 20px;
      z-index: 60;
      justify-content: space-between;
    }

    .toolbar {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 60;
    }
  }
</style>

<script is:inline>
  (function () {
    function $(el, sel) { return el && el.closest ? el.closest(sel) : null; }
    var root = document.documentElement;
    var THEME_KEY = 'rinlit:theme';
    var LANG_KEY = 'rinlit:lang';

    function resolveTheme(mode) {
      if (mode === 'auto' || !mode) {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      return mode;
    }

    function applyTheme(resolved) {
      root.classList.toggle('dark', resolved === 'dark');
      root.style.colorScheme = resolved;
    }

    function setTheme(mode) {
      if (mode === 'auto') localStorage.removeItem(THEME_KEY);
      else localStorage.setItem(THEME_KEY, mode);
      applyTheme(resolveTheme(mode));
    }

    function restoreTheme() {
      var saved = localStorage.getItem(THEME_KEY) || 'auto';
      applyTheme(resolveTheme(saved));
    }

    if (!root.dataset.themeReady) { restoreTheme(); }

    if (!root.dataset.headerEventBound) {
      root.dataset.headerEventBound = '1';

      if (!root.dataset.themeSwapBound) {
        root.dataset.themeSwapBound = '1';
        document.addEventListener('astro:after-swap', restoreTheme);
      }
      if (!root.dataset.themeMediaBound) {
        root.dataset.themeMediaBound = '1';
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function (e) {
          if (localStorage.getItem(THEME_KEY)) return;
          applyTheme(e.matches ? 'dark' : 'light');
        });
      }

      document.addEventListener('menu:change', function (e) {
        var d = e.detail;
        if (d.group === 'theme') setTheme(d.value);
        if (d.group === 'lang') {
          // 存储语言偏好
          localStorage.setItem(LANG_KEY, d.value);
          // 导航到目标语言页面
          var path = window.location.pathname;
          // 移除当前语言前缀，添加目标语言前缀
          var langs = ['en', 'zh-cn'];
          var stripped = path;
          for (var i = 0; i < langs.length; i++) {
            var pattern = new RegExp('^/' + langs[i] + '(/|$)');
            stripped = stripped.replace(pattern, '/');
          }
          var targetPath = '/' + d.value + stripped.replace(/\/+$/, '') || '/';
          window.location.href = targetPath;
        }
      });

      if (!root.dataset.menuBound) {
        root.dataset.menuBound = '1';

        function closeDropdowns(dd) {
          if (!dd) return;
          Menu_close(dd);
        }

        document.addEventListener('click', function (e) {
          var btn = $(e.target, '#menu-trigger');
          if (btn) {
            e.stopPropagation();
            var dd = document.getElementById('settings-menu');
            if (!dd) return;
            if (dd.classList.contains('is-open')) {
              closeDropdowns(dd);
            } else {
              // 关闭用户菜单后再打开 settings
              var um = document.getElementById('user-menu-dropdown');
              if (um?.classList.contains('is-open')) Menu_close(um);
              Menu_open(dd, btn);
            }
            return;
          }

          var inside = $(e.target, '#settings-menu');
          if (!inside) {
            var bodySubs = document.querySelectorAll('body > .menu--sub');
            for (var i = 0; i < bodySubs.length; i++) {
              if (bodySubs[i].contains(e.target)) {
                inside = bodySubs[i];
                break;
              }
            }
          }
          if (!inside) {
            var dd2 = document.getElementById('settings-menu');
            closeDropdowns(dd2);
          }
        });
      }
    }
    root.dataset.themeReady = '1';

    function initMenuChecks() {
      var savedTheme = localStorage.getItem(THEME_KEY) || 'auto';
      var tempLang = localStorage.getItem(LANG_KEY);
      var themeItems = document.querySelectorAll('[data-group="theme"] .menu-item');
      for (var i = 0; i < themeItems.length; i++) {
        var v = themeItems[i].getAttribute('data-value');
        themeItems[i].classList.toggle('menu-item--checked', v === savedTheme);
        themeItems[i].setAttribute('aria-checked', String(v === savedTheme));
      }
      // 语言选中状态：服务端已通过 checked 属性设置，这里也做客户端补齐
      if (tempLang) {
        var langItems = document.querySelectorAll('[data-group="lang"] .menu-item');
        for (var j = 0; j < langItems.length; j++) {
          var lv = langItems[j].getAttribute('data-value');
          langItems[j].classList.toggle('menu-item--checked', lv === tempLang);
          langItems[j].setAttribute('aria-checked', String(lv === tempLang));
        }
      }
    }
    initMenuChecks();
  })();
</script>

<script>
  document.addEventListener('astro:page-load', () => {
    const desktopBtn = document.getElementById('back-btn-desktop');
    const mobileBtn = document.getElementById('back-btn-mobile');
    const logoGroup = desktopBtn?.closest('.nav-pill--logo-group');

    if (!desktopBtn || !mobileBtn) return;

    const path = window.location.pathname;
    const langs = ['en', 'zh-cn'];
    // 去掉语言前缀判断是否首页
    let stripped = path;
    for (var i = 0; i < langs.length; i++) {
      var p = new RegExp('^/' + langs[i] + '$');
      if (p.test(stripped)) { stripped = '/'; break; }
      var p2 = new RegExp('^/' + langs[i] + '(/|$)');
      stripped = stripped.replace(p2, '/');
    }
    const isIndex = stripped === '/' || stripped === '/index';
    const currentPage = path;

    let navStack = JSON.parse(sessionStorage.getItem('nav-stack') || '[]');
    const stackIndex = navStack.indexOf(currentPage);

    if (stackIndex !== -1) {
      navStack = navStack.slice(0, stackIndex + 1);
    } else {
      navStack.push(currentPage);
    }
    sessionStorage.setItem('nav-stack', JSON.stringify(navStack));

    const hasHistory = navStack.length > 1;
    const shouldShow = hasHistory && !isIndex;

    desktopBtn.classList.toggle('is-visible', shouldShow);
    mobileBtn.classList.toggle('is-visible', shouldShow);
    logoGroup?.classList.toggle('nav-pill--has-back', shouldShow);
  });

  document.addEventListener('click', (e) => {
    var target = e.target.closest ? e.target.closest('#back-btn-desktop, #back-btn-mobile') : null;
    if (!target) return;

    e.preventDefault();
    if (window.history.length > 1) {
      window.history.back();
    } else {
      // 回到当前语言的首页
      var langs = ['en', 'zh-cn'];
      var path = window.location.pathname;
      var lang = 'zh-cn';
      for (var i = 0; i < langs.length; i++) {
        if (path.startsWith('/' + langs[i] + '/') || path === '/' + langs[i]) {
          lang = langs[i];
          break;
        }
      }
      window.location.href = '/' + lang;
    }
  });
</script>

<script>
  let authClientPromise: Promise<typeof import('../../lib/auth.client')> | null = null;

  function loadAuthClient() {
    authClientPromise ||= import('../../lib/auth.client');
    return authClientPromise;
  }

  function updateAuthUI() {
    const userArea = document.getElementById('auth-btn-signin')?.closest('.user-area');
    const signinBtn = userArea?.querySelector('#auth-btn-signin') as HTMLElement | null;
    const userMenu = document.getElementById('user-menu');
    const userAccountDisplay = document.getElementById('user-account-display');
    if (!signinBtn || !userMenu) return;

    if (hasSession) {
      signinBtn.style.display = 'none';
      userMenu.style.display = '';
      if (userAccountDisplay && currentUserLabel) {
        userAccountDisplay.textContent = currentUserLabel;
      }
    } else {
      signinBtn.style.display = '';
      userMenu.style.display = 'none';
    }
  }

  let hasSession = false;
  let currentUserLabel = '';

  async function checkSession() {
    try {
      const { getSession } = await loadAuthClient();
      const session = await getSession();
      hasSession = !!session;
      currentUserLabel = session?.user?.user_metadata?.display_name || session?.user?.email || '';
    } catch {
      hasSession = false;
      currentUserLabel = '';
    }
    updateAuthUI();
  }

  // 初始加载 + SPA 导航后都检查 session
  document.addEventListener('astro:page-load', () => {
    checkSession();
  });

  async function bindAuthStateChange() {
    const { onAuthStateChange } = await loadAuthClient();
    onAuthStateChange((event, session) => {
      if (event === 'SIGNED_IN' && session) {
        hasSession = true;
        currentUserLabel = session.user?.user_metadata?.display_name || session.user?.email || '';
        updateAuthUI();
      } else if (event === 'SIGNED_OUT') {
        hasSession = false;
        currentUserLabel = '';
        updateAuthUI();
      }
    });
  }

  if ('requestIdleCallback' in window) {
    window.requestIdleCallback(() => bindAuthStateChange().catch(() => null), { timeout: 2400 });
  } else {
    window.setTimeout(() => bindAuthStateChange().catch(() => null), 600);
  }

  document.addEventListener('auth:signed-in', ((e: CustomEvent) => {
    hasSession = true;
    currentUserLabel = e.detail?.session?.user?.user_metadata?.display_name || e.detail?.session?.user?.email || '';
    updateAuthUI();
  }) as EventListener);

  function getCurrentLang() {
    const path = window.location.pathname;
    return path.startsWith('/en') ? 'en' : 'zh-cn';
  }

  function isAccountPath() {
    return /^\/(en|zh-cn)\/account(?:\/|$)/.test(window.location.pathname);
  }

  async function handleSignOut() {
    const { signOut } = await loadAuthClient();
    await signOut().catch(() => null);
    hasSession = false;
    currentUserLabel = '';
    updateAuthUI();
    const userMenu = document.getElementById('user-menu-dropdown');
    if (userMenu && Menu_close) Menu_close(userMenu);
    if (isAccountPath()) {
      window.location.href = '/' + getCurrentLang();
    }
  }

  // 用户菜单 & 退出登录 — 使用 Menu 组件
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Toggle user dropdown
    const userBtn = target.closest('#auth-btn-user');
    if (userBtn) {
      e.stopPropagation();
      const userMenu = document.getElementById('user-menu-dropdown');
      if (!userMenu) return;
      if (userMenu.classList.contains('is-open')) {
        Menu_close(userMenu);
      } else {
        // 关闭 settings 菜单后再打开用户菜单
        const settings = document.getElementById('settings-menu');
        if (settings?.classList.contains('is-open')) Menu_close(settings);
        Menu_open(userMenu, userBtn as HTMLElement);
      }
      return;
    }

    // Sign out via user menu item
    const userMenuItem = target.closest('#user-menu-dropdown .menu-item');
    if (userMenuItem) {
      e.preventDefault();
      e.stopPropagation();
      const value = userMenuItem.getAttribute('data-value');
      if (value === 'gallery') {
        const path = window.location.pathname;
        const lang = path.startsWith('/en') ? 'en' : 'zh-cn';
        window.location.href = '/' + lang + '/gallery/manage';
      }
      if (value === 'account') {
        const path = window.location.pathname;
        const lang = path.startsWith('/en') ? 'en' : 'zh-cn';
        window.location.href = '/' + lang + '/account';
      }
      if (value === 'signout') handleSignOut();
      return;
    }

    // Close user dropdown when clicking outside
    if (!target.closest('#user-menu-dropdown') && !target.closest('#auth-btn-user')) {
      const userMenu = document.getElementById('user-menu-dropdown');
      if (userMenu?.classList.contains('is-open')) Menu_close(userMenu);
    }
  });
</script>
