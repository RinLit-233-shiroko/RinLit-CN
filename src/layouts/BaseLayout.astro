---
export interface Props {
  lang?: string;
  title: string;
  description?: string;
  image?: string;
}

const {
  lang = 'zh-cn',
  title,
  description = 'RinLit is a personal creative space for software projects, design systems, experiments, writing, and visual ideas.',
  image = '/images/logo/Type=Square, Mode=Light, Monochrome=False.png',
} = Astro.props;

import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import AuthModal from '../features/auth/AuthModal.astro';
import { locales, defaultLocale } from '../i18n/index';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

const safeLang = locales.includes(lang as any) ? lang : defaultLocale;
const currentPath = Astro.url.pathname;
const pageTitle = title.includes('RinLit') ? title : `${title} — RinLit`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
const imageUrl = new URL(image, Astro.site ?? Astro.url.origin).href;
---

<!doctype html>
<html lang={safeLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#fbf9ff" />
    <meta name="keywords" content="RinLit, software, design systems, experimental ideas, portfolio, projects, writing" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="RinLit" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={lang} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <ClientRouter />  

    <script is:inline>
      (function () {
        try {
          var root = document.documentElement;
          var saved = localStorage.getItem('rinlit:theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var mode = saved ? saved : (prefersDark ? 'dark' : 'light');
          root.classList.toggle('dark', mode === 'dark');
          root.classList.toggle('light', mode === 'light');
          root.style.colorScheme = mode;
        } catch (e) {}
      })();
    </script>

    <title>{pageTitle}</title>

    <link rel="icon" href="/favicon/light.ico" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon/dark.ico" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon/light.ico" />
  </head>
  <body class="min-h-screen bg-light text-dark font-sans">
    <Header currentPath={currentPath} lang={safeLang} />
    <main class="pb-28 md:pb-0">
      <slot />
    </main>
    <Footer lang={safeLang} />
    <AuthModal lang={safeLang} />
  </body>
</html>
