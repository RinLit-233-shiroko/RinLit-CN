---
import { t } from '../../../i18n/index';
import Input from '../../../components/Input.astro';
import Button from '../../../components/Button.astro';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const __ = (key: string) => t(lang, key);
---

<div data-page="5" class="auth-modal__page auth-modal__otp-page">
  <div class="auth-modal__email-display" id="auth-otp-email-display">
    <svg class="auth-modal__email-display-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2Z" />
      <path d="m22 6-10 7L2 6" />
    </svg>
    <span class="auth-modal__email-display-text"></span>
  </div>

  <p class="auth-modal__forgot-desc">{__('auth.otpDesc')}</p>

  <div class="auth-modal__field">
    <Input
      type="text"
      name="otp"
      id="auth-otp-code"
      placeholder="000000"
      label={__('auth.otpCode')}
      flat
      required
      autocomplete="one-time-code"
      inputmode="numeric"
      maxlength="6"
      pattern="[0-9]{6}"
    />
    <Button flat class="auth-modal__otp-send-btn">
      <span class="auth-modal__otp-send-label">{__('auth.otpSendAction')}</span>
      <span class="auth-modal__submit-spinner" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
      </span>
    </Button>
  </div>

  <p class="auth-modal__error" id="auth-error-otp" hidden></p>

  <p class="auth-modal__switch">
    <button class="auth-modal__switch-btn" data-action="auth:password-signin" type="button">
      {__('auth.passwordSignIn')}
    </button>
  </p>

  <div class="auth-modal__action">
    <Button primary flat class="auth-modal__otp-submit-btn">
      <span class="auth-modal__otp-submit-label">{__('auth.otpSignInAction')}</span>
      <span class="auth-modal__submit-spinner" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
      </span>
    </Button>
  </div>
</div>
