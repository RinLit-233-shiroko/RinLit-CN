---
import { t } from '../../i18n/index';
import Button from '../../components/Button.astro';

export interface Props {
  lang?: string;
}

const { lang } = Astro.props;
const __ = (key: string) => t(lang, key);
---

<section class="bg-light py-24 transition-colors duration-300">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-title-large font-sans font-bold tracking-tight text-dark">
        {__('gallery.title')}
      </h2>
      <p class="mt-3 text-body-large text-neutral-600">
        {__('gallery.subtitle')}
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button to="gallery" primary flat>{__('gallery.submit')}</Button>
        <Button to="gallery" flat>{__('gallery.go')}</Button>
      </div>
    </div>

    <div class="gallery-preview mt-12 w-full rounded-2xl shadow-sm" style="aspect-ratio: 1440/520">
    </div>
  </div>
</section>

<style>
  .gallery-preview {
    background: var(--bg-muted);
    transition: background-color 0.25s ease;
  }
</style>
