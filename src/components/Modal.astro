---
// Modal — 通用模态窗口组件
//
// 提供遮罩层、sticky 顶栏(返回按钮+标题+关闭按钮)、多页面切换、ESC关闭、点击外部关闭、滚动锁定等。
// 内容通过 <slot /> 注入。
//
// Props:
//   id         — DOM id（必填，用于全局引用 window.__modals[id]）
//   title      — 窗口顶栏标题（可选，可通过 setTitle() 动态更新）
//   class      — 附加到卡片上的 CSS 类
//   ariaLabel  — aria-label 无障碍标签
//
// 多页面支持:
//   在 slot 内容中使用 data-page="N" 标记页面:
//     <div data-page="0">第一页</div>
//     <div data-page="1">第二页</div>
//   通过 modal.goToPage(n) / modal.goBack() 切换页面。
//   返回按钮仅在非首页时显示。

import Button from './Button.astro';

interface Props {
  id: string;
  title?: string;
  class?: string;
  ariaLabel?: string;
}

const { id = 'modal', title = '', class: cardClass = '', ariaLabel = '' } = Astro.props;
---

<div
  class="modal"
  id={id}
  inert
  role="dialog"
  aria-modal="true"
  aria-label={ariaLabel || title}
>
  <div class="modal__backdrop"></div>
  <div class={`modal__card ${cardClass}`}>
    <!-- 顶栏 — sticky -->
    <div class="modal__topbar">
      <div class="modal__back-wrap" data-action="modal:back" hidden>
        <Button icon="chevron-left" flat class="modal__back-btn" aria-label="Back" />
      </div>
      <span class="modal__topbar-title">{title}</span>
      <div class="modal__close-wrap" data-action="modal:close">
        <Button icon="x" flat class="modal__close-btn" aria-label="Close" />
      </div>
    </div>
    <!-- 内容区 — 可滚动 -->
    <div class="modal__content">
      <slot />
    </div>
  </div>
</div>

<style>
  .modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(16, 18, 22, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  :root.dark .modal__backdrop {
    background: rgba(0, 0, 0, 0.55);
  }

  .modal__card {
    position: relative;
    z-index: 1;
    width: 380px;
    max-width: calc(100vw - 48px);
    max-height: calc(100vh - 48px);
    border-radius: 24px;
    background: var(--bg-elevated);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      0 20px 60px rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .modal__card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(255, 255, 255, 0) 46%,
      rgba(255, 255, 255, 0) 56%,
      rgba(255, 255, 255, 0.18) 100%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  :root.dark .modal__card {
    background: color-mix(in srgb, var(--bg-elevated) 70%, transparent);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 24px 72px rgba(0, 0, 0, 0.5);
  }

  /* ======== 顶栏 — sticky ======== */
  .modal__topbar {
    position: sticky;
    top: 0;
    z-index: 2;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    padding: 12px;
    min-height: 48px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.06) 0%, transparent 100%);
    border-radius: 24px 24px 0 0;
  }

  :root.dark .modal__topbar {
    background: linear-gradient(to bottom, rgba(255,255,255,0.06) 0%, transparent 100%);
  }

  .modal__topbar-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: var(--text-strong);
    white-space: nowrap;
    pointer-events: none;
  }

  /* 返回按钮容器 — 左对齐 */
  .modal__back-wrap {
    display: flex;
    align-items: center;
  }

  .modal__back-wrap[hidden] {
    display: none;
  }

  /* 关闭按钮容器 — 右对齐 */
  .modal__close-wrap {
    margin-left: auto;
    display: flex;
    align-items: center;
  }

  /* ======== 内容区 — 可滚动 ======== */
  .modal__content {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 0 28px 24px;
  }
</style>

<script>
  // 实时 DOM 查找 + 事件委托，不缓存任何 DOM 引用
  window.__modals = window.__modals || {};

  class Modal {
    readonly id: string;
    private _currentPage = 0;

    constructor(el: HTMLElement) {
      this.id = el.id;
    }

    open() {
      const el = document.getElementById(this.id);
      if (!el) return;
      this.goToPage(0, true); // 打开时重置到首页
      el.classList.add('is-open');
      el.removeAttribute('inert');
      document.body.style.overflow = 'hidden';
      document.dispatchEvent(new CustomEvent('modal:opened', { detail: { id: this.id } }));
    }

    close() {
      const el = document.getElementById(this.id);
      if (!el) return;
      el.classList.remove('is-open');
      el.setAttribute('inert', '');
      document.body.style.overflow = '';
      document.dispatchEvent(new CustomEvent('modal:closed', { detail: { id: this.id } }));
    }

    /** 设置顶栏标题 */
    setTitle(title: string) {
      const el = document.getElementById(this.id);
      if (!el) return;
      const titleEl = el.querySelector('.modal__topbar-title');
      if (titleEl) titleEl.textContent = title;
    }

    /** 切换到指定页面 */
    goToPage(index: number, silent = false) {
      const el = document.getElementById(this.id);
      if (!el) return;
      const pages = el.querySelectorAll('.modal__content > [data-page]');
      const totalPages = pages.length;

      // 无页面系统时忽略
      if (totalPages === 0) return;

      const clamped = Math.max(0, Math.min(index, totalPages - 1));
      this._currentPage = clamped;

      pages.forEach((page, i) => {
        (page as HTMLElement).style.display = i === clamped ? '' : 'none';
      });

      // 切换返回按钮可见性
      const backWrap = el.querySelector('.modal__back-wrap') as HTMLElement;
      if (backWrap) backWrap.hidden = clamped === 0;

      if (!silent) {
        document.dispatchEvent(new CustomEvent('modal:page-changed', {
          detail: { id: this.id, page: clamped, totalPages },
        }));
      }
    }

    /** 返回上一页 */
    goBack() {
      if (this._currentPage > 0) {
        this.goToPage(this._currentPage - 1);
      }
    }

    /** 当前页面索引 */
    get currentPage(): number {
      return this._currentPage;
    }

    /** 总页数 */
    get totalPages(): number {
      const el = document.getElementById(this.id);
      if (!el) return 0;
      return el.querySelectorAll('.modal__content > [data-page]').length;
    }
  }

  document.querySelectorAll('.modal').forEach((el) => {
    window.__modals[el.id] = new Modal(el as HTMLElement);
  });

  // 全局委托 — 返回按钮 / 关闭按钮 / 背景遮罩
  document.addEventListener('click', (e) => {
    // 返回按钮 (data-action="modal:back")
    const backBtn = (e.target as HTMLElement).closest('[data-action="modal:back"]');
    if (backBtn) {
      const modalEl = backBtn.closest('.modal');
      if (modalEl && window.__modals[modalEl.id]) {
        window.__modals[modalEl.id].goBack();
      }
      return;
    }

    // 关闭按钮 (data-action="modal:close")
    const closeBtn = (e.target as HTMLElement).closest('[data-action="modal:close"]');
    if (closeBtn) {
      const modalEl = closeBtn.closest('.modal');
      if (modalEl && window.__modals[modalEl.id]) {
        window.__modals[modalEl.id].close();
      }
      return;
    }

    // 背景遮罩
    const backdrop = (e.target as HTMLElement).closest('.modal__backdrop');
    if (backdrop) {
      const modalEl = backdrop.closest('.modal');
      if (modalEl && window.__modals[modalEl.id]) {
        window.__modals[modalEl.id].close();
      }
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    Object.keys(window.__modals).forEach((id) => {
      const el = document.getElementById(id);
      if (el?.classList.contains('is-open')) {
        window.__modals[id].close();
      }
    });
  });
</script>
