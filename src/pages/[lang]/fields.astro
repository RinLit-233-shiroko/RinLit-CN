---
import { locales } from '../../i18n/index';
import { t } from '../../i18n/index';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Link from '../../components/Link.astro';
import Input from '../../components/Input.astro';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const __ = (key: string) => t(lang, key);
---

<BaseLayout lang={lang} title={`${__('page.fields')} — Fields — RinLit`}>
  <main class="mx-auto flex min-h-screen max-w-5xl items-center px-6">
    <div>
      <p class="text-section-label font-display uppercase tracking-[0.25em] text-primary-600">{__('page.fields')}</p>
      <h1 class="mt-4 text-hero font-display tracking-tight text-dark">{__('page.fields')}</h1>
      <p class="mt-6 text-body-large text-neutral-800">{__('page.fields.desc')}</p>
      <nav class="mt-8 flex gap-4">
        <Link to="fields/software" class="rounded-pill border border-neutral-400 px-6 py-2 text-body hover:bg-neutral-100">{__('page.fields.software')}</Link>
        <Link to="fields/design" class="rounded-pill border border-neutral-400 px-6 py-2 text-body hover:bg-neutral-100">{__('page.fields.design')}</Link>
        <Link to="fields/experiment" class="rounded-pill border border-neutral-400 px-6 py-2 text-body hover:bg-neutral-100">{__('page.fields.experiment')}</Link>
        <Input type="text" placeholder={__('page.fields.search')} />
      </nav>
    </div>
  </main>
</BaseLayout>
