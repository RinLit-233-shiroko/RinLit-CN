---
// Figma: NavigationButton 组件
//
// Desktop: 透明底, 无边框, 横排文字
//   padding: 6/24, gap: 6, font: 17px
//   hover: #000 8%, press: 淡 opacity, active: #000 6% + primary 字色
//
// Mobile: 上图标 + 下文字 竖排
//   icon: 24px, font: 12px, padding: 6/24, gap: 6

import { getIcon } from '../utils/icons';

interface Props {
  active?: boolean;
  href?: string;
  icon?: string;
  class?: string;
}

const { active = false, href, icon = '', class: className = '' } = Astro.props;

const Tag = href ? 'a' : 'button';

const svgHtml = getIcon(icon, 24);
---

<Tag
  href={href}
  class={`nav-btn ${active ? 'nav-btn--active' : ''} ${className}`}
>
  {
    svgHtml && (
      <span class="nav-btn__icon" set:html={svgHtml} />
    )
  }
  <span class="nav-btn__label"><slot /></span>
</Tag>

<style>
  .nav-btn {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    gap: 6px;
    padding: 6px 24px;
    border-radius: 27px;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 700;
    font-size: 17px;
    color: var(--text);
    background: transparent;
    border: none;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
    user-select: none;

    -webkit-user-drag: none;
    user-drag: none;

    cursor: default;
  }

  .nav-btn:hover {
    background: var(--border-strong);
  }

  .nav-btn:active {
    opacity: 0.6;
  }

  .nav-btn--active {
    background: var(--border);
    color: var(--color-primary-500);
  }

  /* ======== 图标：Desktop 隐藏，Mobile 显示 ======== */
  .nav-btn__icon {
    display: none;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .nav-btn__icon :global(svg) {
    width: 24px;
    height: 24px;
    display: block;
  }

  .nav-btn__label {
    display: block;
    line-height: 21px;
  }

  /* ======== Mobile: 上 icon + 下文字，clamp() 等比缩放 ======== */
  @media (max-width: 768px) {
    .nav-btn {
      flex-direction: column;
      padding: clamp(4px, 1.58vw, 6px) clamp(12px, 6.32vw, 24px);
      gap: clamp(4px, 1.58vw, 6px);
      font-size: clamp(8px, 3.16vw, 12px);
      text-align: center;
    }

    .nav-btn__label {
      display: block;
      line-height: normal;
    }

    .nav-btn__icon {
      display: block;
      width: clamp(17px, 6.32vw, 24px);
      height: clamp(17px, 6.32vw, 24px);
    }

    .nav-btn__icon :global(svg) {
      width: clamp(17px, 6.32vw, 24px);
      height: clamp(17px, 6.32vw, 24px);
    }
  }

  /* ===== 超窄屏：继承 Header 的 --scale 等比缩放 (≤474px) ===== */
  @media (max-width: 474px) {
    .nav-btn {
      padding: calc(6px * var(--scale, 1)) calc(24px * var(--scale, 1));
      gap: calc(6px * var(--scale, 1));
      font-size: calc(12px * var(--scale, 1));
    }

    .nav-btn__icon {
      width: calc(24px * var(--scale, 1));
      height: calc(24px * var(--scale, 1));
    }

    .nav-btn__icon :global(svg) {
      width: calc(24px * var(--scale, 1));
      height: calc(24px * var(--scale, 1));
    }
  }
</style>