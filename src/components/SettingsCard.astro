---
interface Props {
  flat?: boolean;
  asRow?: boolean;
  class?: string;
  id?: string;
  href?: string;
}

const { flat = true, asRow = false, class: className = '', id = '', href = '' } = Astro.props;
const Tag = asRow ? (href ? 'a' : 'div') : 'article';
const interactive = Boolean(asRow && href);
---

<Tag
  id={id}
  href={asRow && href ? href : undefined}
  class={`settings-card ${flat ? 'settings-card--flat' : ''} ${asRow ? 'settings-card--row' : ''} ${interactive ? 'settings-card--interactive' : ''} ${className}`}
>
  <span class="settings-card__bg-layer" aria-hidden="true">
    {interactive && <span class="settings-card__glow" aria-hidden="true"></span>}
  </span>
  <slot />
</Tag>

<style>
  .settings-card {
    position: relative;
    z-index: 0;
    border: none;
    border-radius: var(--pill-radius, 24px);
    background: transparent;
    transition:
      background-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.2s ease;
  }

  .settings-card--interactive {
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
    -webkit-user-drag: none;
    user-drag: none;
  }

  .settings-card.is-pressed {
    transform: scale(1.03);
  }

  .settings-card--dragging {
    transition: transform 0ms !important;
  }

  .settings-card__bg-layer {
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    overflow: hidden;
    background: color-mix(in srgb, var(--pill-bg-hover) 72%, transparent);
    /* box-shadow: 0 4px 10px color-mix(in srgb, var(--pill-shadow) 58%, transparent); */
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    pointer-events: none;
  }

  .settings-card__bg-layer::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    padding: 2px;
    background: var(--border-gradient);
    opacity: 0.6;
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .settings-card--flat .settings-card__bg-layer {
    /* box-shadow: 0 1px 4px color-mix(in srgb, var(--pill-shadow) 46%, transparent); */
  }

  .settings-card:not(.settings-card--row) {
    padding: 22px;
  }

  .settings-card--row {
    min-height: 76px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    color: var(--text);
    text-decoration: none;
  }

  @media (hover: hover) {
    .settings-card--interactive:hover .settings-card__bg-layer {
      background: color-mix(in srgb, var(--pill-bg-hover) 76%, transparent);
    }
  }

  .settings-card--interactive:active .settings-card__bg-layer {
    background: color-mix(in srgb, var(--pill-bg-active) 78%, transparent);
  }

  .settings-card__glow {
    position: absolute;
    z-index: 1;
    width: 78px;
    height: 78px;
    border-radius: 50%;
    background: var(--glow);
    filter: blur(32px);
    -webkit-filter: blur(32px);
    pointer-events: none;
    opacity: 0;
    transform: translate(-50%, -50%);
    will-change: left, top, opacity;
    transition: opacity 300ms cubic-bezier(0.4, 0, 1, 1);
  }

  .settings-card__glow.is-visible {
    opacity: 1;
    transition: opacity 150ms cubic-bezier(.16,.49,0,.99);
  }
</style>

<script is:inline>
  (function () {
    function closest(el, sel) { return el && el.closest ? el.closest(sel) : null; }

    document.addEventListener('pointerdown', function (e) {
      var card = closest(e.target, '.settings-card--interactive');
      if (!card) return;
      var glow = card.querySelector('.settings-card__glow');
      if (!glow) return;
      if (card.classList.contains('settings-card--dragging')) return;

      var startX = e.clientX;
      var startY = e.clientY;
      var rect = card.getBoundingClientRect();

      enter(card, glow, rect, e);

      function onMove(ev) { move(card, glow, startX, startY, ev); }
      function onUp() { leave(card, glow); cleanup(); }

      function cleanup() {
        document.removeEventListener('pointermove', onMove);
        document.removeEventListener('pointerup', onUp);
        document.removeEventListener('pointerleave', onUp);
      }

      document.addEventListener('pointermove', onMove);
      document.addEventListener('pointerup', onUp);
      document.addEventListener('pointerleave', onUp);
    });

    function enter(card, glow, rect, e) {
      card.classList.add('is-pressed');
      glow.classList.add('is-visible');
      glow.style.left = (e.clientX - rect.left) + 'px';
      glow.style.top = (e.clientY - rect.top) + 'px';
    }

    function move(card, glow, sx, sy, e) {
      if (!card.classList.contains('settings-card--dragging')) {
        var cur = getComputedStyle(card).transform;
        card.classList.remove('is-pressed');
        card.classList.add('settings-card--dragging');
        card.style.transform = cur !== 'none' ? cur : 'scale(1.03)';
        requestAnimationFrame(function () { computeDrag(card, glow, sx, sy, e); });
        return;
      }
      computeDrag(card, glow, sx, sy, e);
    }

    function computeDrag(card, glow, sx, sy, e) {
      var dx = e.clientX - sx;
      var dy = e.clientY - sy;
      var maxDisp = 5;
      var tx = Math.sign(dx) * maxDisp * (1 - 1 / (1 + Math.abs(dx) / 80));
      var ty = Math.sign(dy) * maxDisp * (1 - 1 / (1 + Math.abs(dy) / 80));
      var scaleX = 1 + 0.03 / (1 + Math.abs(dy) / 120);
      var scaleY = 1 + 0.03 / (1 + Math.abs(dx) / 120);

      card.style.transform = 'translate(' + tx + 'px, ' + ty + 'px) scale(' + scaleX + ', ' + scaleY + ')';

      var r = card.getBoundingClientRect();
      glow.style.left = (e.clientX - r.left) + 'px';
      glow.style.top = (e.clientY - r.top) + 'px';
    }

    function leave(card, glow) {
      card.classList.remove('settings-card--dragging');
      card.classList.remove('is-pressed');
      card.style.transform = '';
      glow.classList.remove('is-visible');
    }
  })();
</script>
