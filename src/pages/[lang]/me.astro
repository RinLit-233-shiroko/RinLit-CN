---
import { locales } from '../../i18n/index';
import { t } from '../../i18n/index';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const __ = (key: string) => t(lang, key);
---

<BaseLayout lang={lang} title={`${__('page.me')} — RinLit`}>
  <main class="mx-auto flex min-h-screen max-w-5xl items-center px-6">
    <div>
      <p class="text-section-label font-display uppercase tracking-[0.25em] text-primary-600">{__('page.me')}</p>
      <h1 class="mt-4 text-hero font-display tracking-tight text-dark">{__('page.me')}</h1>
      <p class="mt-6 text-body-large text-neutral-800">{__('page.me.desc')}</p>
    </div>
  </main>
</BaseLayout>
