---
// Figma: Button 组件
//
// Pill 组件提供 45° 渐变边框、阴影、背景模糊。
// Button 只负责布局、文字、交互状态。
// 亮/暗色由 CSS 变量自动切换，无需手动指定 variant。

import Pill from './Pill.astro';
import { getIcon } from '../utils/icons';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  primary?: boolean;
  href?: string;
  /** i18n-aware 路由路径（自动添加语言前缀） */
  to?: string;
  icon?: string;
  id?: string;
  class?: string;
  flat?: boolean;
  [key: string]: unknown;
}

const {
  primary = false,
  href,
  to,
  icon = '',
  id = '',
  class: className = '',
  flat = false,
  ...attrs
} = Astro.props;

const resolvedHref = to ? getRelativeLocaleUrl(Astro.currentLocale!, to) : href;
const Tag = resolvedHref ? 'a' : 'button';
const isIconOnly = !Astro.slots.has('default');
const svgHtml = getIcon(icon, 18);
---

<Pill primary={primary} flat={flat} id={id} class={className}>
  <Tag href={resolvedHref} class={`btn ${isIconOnly ? 'btn--icon-only' : ''}`} {...attrs}>
    {svgHtml && (
      <span class="btn__icon">
        <span set:html={svgHtml} />
      </span>
    )}
    {!isIconOnly && <span class="btn__text"><slot /></span>}
  </Tag>
</Pill>

<style>
  /* ======== 按钮基础布局 ======== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    height: 40px;
    padding: 0 24px;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-weight: 700;
    font-size: 17px;
    background: transparent;
    border: none;
    text-decoration: none;
    color: var(--text-strong);
    cursor: pointer;
    transition: opacity 0.2s ease;
    -webkit-user-drag: none;
    user-drag: none;
    user-select: none;
  }

  /* ======== primary 文字色 ======== */
  :global(.pill--primary) .btn {
    color: #ffffff;
  }

  /* ======== 纯图标模式 ======== */
  .btn--icon-only {
    width: 40px;
    padding: 0;
  }

  /* ======== 图标 ======== */
  .btn__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    position: relative;
  }

  .btn__icon :global(svg) {
    width: 20px;
    height: 20px;
    display: block;
  }

  .btn__text {
    display: grid;
    place-items: center;
    flex: 1 1 auto;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .btn__text :global(*) {
    min-width: 0;
    max-width: 100%;
  }

  .btn__text > :global(*) {
    min-width: 0;
    max-width: 100%;
  }

  .btn__text > :global([class*='spinner']:not([hidden])) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    margin: 0 auto;
    overflow: visible;
  }

  .btn__text > :global(*:not([hidden]):not([class*='spinner'])) {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .btn__text :global([hidden]) {
    display: none !important;
  }

  .btn__text :global([class*='spinner'] svg) {
    display: block;
    width: 18px;
    height: 18px;
  }
</style>
