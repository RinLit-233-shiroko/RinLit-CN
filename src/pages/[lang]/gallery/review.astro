---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Button from '../../../components/Button.astro';
import SettingsCard from '../../../components/SettingsCard.astro';
import NavigationBar from '../../../components/NavigationBar.astro';
import ModerationToolbar from '../../../components/gallery/ModerationToolbar.astro';
import GalleryAdminTable from '../../../components/gallery/GalleryAdminTable.astro';
import { getIcon } from '../../../utils/icons';
import { locales, t } from '../../../i18n/index';

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang = 'zh-cn' } = Astro.params;
const __ = (key: string) => t(lang, key);
const icons = {
  list: getIcon('layout-list', 18),
  grid: getIcon('layout-grid', 18),
  shield: getIcon('shield-check', 18),
};
---

<BaseLayout lang={lang} title={`${__('gallery.reviewPage')} — RinLit`} description={__('gallery.reviewDesc')}>
  <section class="gallery-admin-page">
    <div class="gallery-admin-topbar">
      <a class="gallery-admin-brand" href={`/${lang}/gallery`} aria-label="Gallery">
        <img class="gallery-admin-brand__img gallery-admin-brand__img--light" src="/images/logo/Type=Horizontal, Mode=Light, Monochrome=False.png" alt="RinLit" />
        <img class="gallery-admin-brand__img gallery-admin-brand__img--dark" src="/images/logo/Type=Horizontal, Mode=Dark, Monochrome=False.png" alt="RinLit" />
        <span>{__('gallery.reviewPage')}</span>
      </a>
      <Button href={`/${lang}/gallery/manage`} flat>{__('gallery.manageSubmissions')}</Button>
    </div>

    <main class="gallery-admin-main" id="gallery-review-main" hidden>
      <aside class="gallery-admin-sidebar" aria-label={__('gallery.reviewNav')}>
        <div class="gallery-admin-identity">
          <strong id="gallery-review-name">RinLit</strong>
          <span id="gallery-review-email">...</span>
        </div>
        <NavigationBar
          className="gallery-admin-nav"
          itemClassName="gallery-admin-nav__item"
          items={[
            { key: 'submit', label: __('gallery.newSubmission'), kind: 'link', href: `/${lang}/gallery/submit` },
            { key: 'manage', label: __('gallery.manageSubmissions'), kind: 'link', href: `/${lang}/gallery/manage` },
            { key: 'favorites', label: __('gallery.favorites'), kind: 'link', href: `/${lang}/gallery/favorites` },
            { key: 'review', label: __('gallery.masterReview'), kind: 'link', href: `/${lang}/gallery/review`, active: true, attrs: { 'data-review-nav': 'true' } },
          ]}
        />
      </aside>

      <section class="gallery-admin-content">
        <h1 class="panel-title">{__('gallery.masterReview')}</h1>

        <SettingsCard class="master-review-card" id="gallery-master-review-card">
          <div class="card-head">
            <div class="card-icon" set:html={icons.shield}></div>
            <div class="card-copy">
              <h2>{__('gallery.masterReview')}</h2>
              <p>{__('gallery.masterReviewDesc')}</p>
            </div>
          </div>

        <ModerationToolbar
          filterGroupLabel={__('gallery.reviewFilters')}
          layoutGroupLabel={__('gallery.reviewListLayout')}
          filterItems={[
            { key: 'ALL', label: __('gallery.all') },
            { key: 'SUBMISSION', label: __('gallery.reviewSubmissions') },
            { key: 'REMOVAL', label: __('gallery.reviewRemovals') },
          ]}
          viewItems={[
            { key: 'list', label: __('gallery.listLayout'), icon: icons.list },
            { key: 'grid', label: __('gallery.gridLayout'), icon: icons.grid },
          ]}
          activeFilter="ALL"
          activeView="list"
          filterAttrName="data-moderation-filter"
          viewAttrName="data-moderation-view"
        />

          <GalleryAdminTable
            id="gallery-moderation-list"
            class="moderation-list"
            columns={[
              { label: __('gallery.manage.tableArtwork'), width: '36%' },
              { label: __('gallery.manage.tableType'), width: '112px' },
              { label: __('gallery.manage.tableTime'), width: '128px' },
              { label: __('gallery.manage.tableReason'), width: '22%' },
              { label: __('gallery.manage.tableActions'), width: '156px' },
            ]}
          />
          <p class="submission-empty" id="gallery-moderation-empty" hidden>{__('gallery.noPending')}</p>
          <template id="gallery-moderation-template">
            <tr class="gallery-admin-table__row moderation-item" id="gallery-moderation-template-card">
              <td>
                <div class="gallery-admin-table__media">
                  <figure class="gallery-admin-table__figure">
                    <img class="gallery-admin-table__image" data-moderation-image alt="" loading="lazy" />
                  </figure>
                  <div class="gallery-admin-table__meta">
                    <h2 class="gallery-admin-table__title" data-moderation-title></h2>
                    <p class="gallery-admin-table__description" data-moderation-description hidden></p>
                  </div>
                </div>
              </td>
              <td>
                <span class="gallery-admin-table__badge moderation-item__type" data-moderation-type-label></span>
              </td>
              <td>
                <time class="gallery-admin-table__time" data-moderation-time></time>
              </td>
              <td>
                <div class="gallery-admin-table__reason moderation-reason">
                  <span data-moderation-reason></span>
                </div>
              </td>
              <td>
                <div class="moderation-actions">
                <p class="form-message" data-message></p>
                <div class="moderation-actions__buttons">
                  <Button primary flat class="moderation-action">
                    <span data-moderation-approve>{__('gallery.approve')}</span>
                    <span class="btn-spinner" data-moderation-approve-spinner hidden>
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                      </svg>
                    </span>
                  </Button>
                  <Button flat class="moderation-action">
                    <span data-moderation-reject>{__('gallery.reject')}</span>
                    <span class="btn-spinner" data-moderation-reject-spinner hidden>
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                      </svg>
                    </span>
                  </Button>
                </div>
              </div>
              </td>
            </tr>
          </template>
        </SettingsCard>
      </section>
    </main>

    <section class="gallery-admin-state" id="gallery-review-gate">
      <span>{__('gallery.checkingAccess')}</span>
    </section>
  </section>
</BaseLayout>

<script is:inline define:vars={{
  __GALLERY_REVIEW_I18N: JSON.stringify({
    defaultError: __('gallery.manage.error'),
    approved: __('gallery.manage.approved'),
    rejected: __('gallery.manage.rejected'),
    approving: __('gallery.manage.approving'),
    reviewTypeSubmission: __('gallery.manage.reviewTypeSubmission'),
    reviewTypeRemoval: __('gallery.manage.reviewTypeRemoval'),
    noReviewReason: __('gallery.manage.noReviewReason'),
    noFilteredRequests: __('gallery.manage.noFilteredRequests'),
    noPendingRequests: __('gallery.noPending'),
    notSignedIn: __('gallery.submit.notSignedIn'),
    masterOnly: __('gallery.submit.userOnly'),
    loading: __('gallery.checkingAccess'),
  })
}}>
  window.__GALLERY_REVIEW_I18N = JSON.parse(__GALLERY_REVIEW_I18N);
</script>

<script>
  import { getUser, hasRole, onAuthStateChange } from '../../../lib/auth.client';
  import { fetchPendingGalleryModerationRequests, decideGalleryModerationRequest } from '../../../lib/gallery.client';
  import type { GalleryItemModerationRequestType, GalleryItemStatus } from '../../../lib/database.types';

  const text = (window as any).__GALLERY_REVIEW_I18N || {};
  let currentUser: any = null;
  let cleanupGalleryReview: (() => void) | null = null;

  type TagRelation = { gallery_tags?: { id: string; name: string } | { id: string; name: string }[] | null };
  type ItemRow = {
    id: string;
    title: string | null;
    description: string | null;
    image_url: string;
    created_at: string | null;
    status: GalleryItemStatus;
    gallery_item_tags?: TagRelation[] | null;
  };
  type ModerationRow = {
    id: string;
    gallery_item_id: string;
    user_id: string;
    reason: string | null;
    status: string;
    created_at: string;
    decided_at: string | null;
    request_type: GalleryItemModerationRequestType;
    gallery_items?: ItemRow | ItemRow[] | null;
  };

  function showLoginRequired() {
    const next = encodeURIComponent(window.location.pathname + window.location.search);
    window.location.replace(`/${document.documentElement.lang}/account/redirect?next=${next}`);
  }

  function getDisplayName(user: any) {
    return user?.user_metadata?.display_name || user?.user_metadata?.full_name || user?.email?.split('@')[0] || 'RinLit';
  }

  function escapeHtml(value: string) {
    return value.replace(/[&<>'"]/g, (char: string) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      "'": '&#39;',
      '"': '&quot;',
    })[char] || char);
  }

  function getModerationItem(row: ModerationRow) {
    const item = row.gallery_items;
    return Array.isArray(item) ? item[0] : item;
  }

  function renderModerationRequest(row: ModerationRow) {
    const item = getModerationItem(row);
    const template = document.getElementById('gallery-moderation-template') as HTMLTemplateElement | null;
    if (!item || !template) return null;

    const fragment = template.content.cloneNode(true) as DocumentFragment;
    const card = fragment.querySelector('.moderation-item') as HTMLElement | null;
    const image = fragment.querySelector('[data-moderation-image]') as HTMLImageElement | null;
    const typeLabel = fragment.querySelector('[data-moderation-type-label]') as HTMLElement | null;
    const title = fragment.querySelector('[data-moderation-title]') as HTMLElement | null;
    const time = fragment.querySelector('[data-moderation-time]') as HTMLTimeElement | null;
    const description = fragment.querySelector('[data-moderation-description]') as HTMLElement | null;
    const reason = fragment.querySelector('[data-moderation-reason]') as HTMLElement | null;
    const approve = fragment.querySelector('[data-moderation-approve]')?.closest('button') as HTMLButtonElement | null;
    const reject = fragment.querySelector('[data-moderation-reject]')?.closest('button') as HTMLButtonElement | null;
    if (!card || !image || !typeLabel || !title || !time || !description || !reason || !approve || !reject) return null;

    const requestTypeLabel = row.request_type === 'REMOVAL' ? text.reviewTypeRemoval : text.reviewTypeSubmission;

    card.removeAttribute('id');
    card.setAttribute('data-request-id', row.id);
    card.setAttribute('data-gallery-item-id', row.gallery_item_id);
    card.setAttribute('data-request-type', row.request_type);
    image.src = item.image_url;
    image.alt = item.title || 'Gallery image';
    typeLabel.textContent = requestTypeLabel;
    typeLabel.setAttribute('data-request-type', row.request_type);
    title.textContent = item.title || 'Untitled';
    title.title = item.title || 'Untitled';
    time.dateTime = row.created_at;
    time.textContent = row.created_at ? new Intl.DateTimeFormat(document.documentElement.lang, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }).format(new Date(row.created_at)) : '';
    description.textContent = item.description || '';
    description.title = item.description || '';
    description.hidden = !item.description;
    reason.textContent = row.reason || text.noReviewReason;
    reason.title = row.reason || text.noReviewReason;
    approve.setAttribute('data-decision', 'APPROVED');
    reject.setAttribute('data-decision', 'REJECTED');

    return fragment;
  }

  function applyModerationView(reviewList: HTMLElement, reviewEmpty: HTMLElement) {
    const filter = reviewList.getAttribute('data-filter') || 'ALL';
    const items = Array.from(reviewList.querySelectorAll('[data-request-id]')) as HTMLElement[];
    let visibleCount = 0;

    items.forEach((item) => {
      const matches = filter === 'ALL' || item.getAttribute('data-request-type') === filter;
      item.hidden = !matches;
      if (matches) visibleCount += 1;
    });

    reviewEmpty.textContent = items.length === 0 ? text.noPendingRequests : text.noFilteredRequests;
    reviewEmpty.hidden = visibleCount > 0;
  }

  async function initGalleryReviewPage() {
    cleanupGalleryReview?.();

    const main = document.getElementById('gallery-review-main');
    const gate = document.getElementById('gallery-review-gate');
    const name = document.getElementById('gallery-review-name');
    const email = document.getElementById('gallery-review-email');
    const reviewList = document.getElementById('gallery-moderation-list');
    const reviewEmpty = document.getElementById('gallery-moderation-empty');
    if (!main || !gate || !name || !email || !reviewList || !reviewEmpty) return;

    reviewList.setAttribute('data-view', 'list');
    reviewList.closest('.gallery-admin-table')?.setAttribute('data-view', 'list');

    const { user, error } = await getUser();
    if (error || !user) {
      showLoginRequired();
      return;
    }

    const isMaster = await hasRole(user.id, 'MASTER');

    if (!isMaster) {
      // Redirect non-master to manage page
      window.location.replace(`/${document.documentElement.lang}/gallery/manage`);
      return;
    }

    currentUser = user;
    name.textContent = getDisplayName(user);
    email.textContent = user.email || '';
    gate.hidden = true;
    main.hidden = false;

    const reviewResult = await fetchPendingGalleryModerationRequests();
    if (reviewResult.error) {
      reviewList.innerHTML = '';
      reviewEmpty.hidden = false;
      reviewEmpty.textContent = reviewResult.error.message || text.defaultError;
    } else {
      const reviewRows = (reviewResult.data || []) as unknown as ModerationRow[];
      reviewList.innerHTML = '';
      reviewRows.forEach((row) => {
        const node = renderModerationRequest(row);
        if (node) reviewList.append(node);
      });
      applyModerationView(reviewList, reviewEmpty);
    }

    const disposers: Array<() => void> = [];
    const unsubscribeAuth = onAuthStateChange((event) => {
      if (event === 'SIGNED_OUT') showLoginRequired();
    });
    disposers.push(unsubscribeAuth);

    const filterButtons = Array.from(document.querySelectorAll('[data-moderation-filter]')) as HTMLButtonElement[];
    const viewButtons = Array.from(document.querySelectorAll('[data-moderation-view]')) as HTMLButtonElement[];

    const onFilterClick = (event: Event) => {
      const button = (event.currentTarget || event.target) as HTMLButtonElement;
      const filter = button.getAttribute('data-moderation-filter') || 'ALL';
      reviewList.setAttribute('data-filter', filter);
      filterButtons.forEach((item) => item.classList.toggle('is-active', item === button));
      applyModerationView(reviewList, reviewEmpty);
    };

    const onViewClick = (event: Event) => {
      const button = (event.currentTarget || event.target) as HTMLButtonElement;
      reviewList.setAttribute('data-view', 'list');
      reviewList.closest('.gallery-admin-table')?.setAttribute('data-view', 'list');
      viewButtons.forEach((item) => item.classList.toggle('is-active', item === button));
    };

    filterButtons.forEach((button) => {
      button.addEventListener('click', onFilterClick);
      disposers.push(() => button.removeEventListener('click', onFilterClick));
    });

    viewButtons.forEach((button) => {
      button.addEventListener('click', onViewClick);
      disposers.push(() => button.removeEventListener('click', onViewClick));
    });

    const onModerationClick = async (event: Event) => {
      const button = (event.target as HTMLElement).closest('[data-decision]') as HTMLButtonElement | null;
      if (!button) return;
      const item = button.closest('[data-request-id]') as HTMLElement | null;
      if (!item) return;

      const requestId = item.getAttribute('data-request-id') || '';
      const galleryItemId = item.getAttribute('data-gallery-item-id') || '';
      const requestType = item.getAttribute('data-request-type') as 'SUBMISSION' | 'REMOVAL' | null;
      const decision = button.getAttribute('data-decision') as 'APPROVED' | 'REJECTED' | null;
      const message = item.querySelector('[data-message]') as HTMLElement | null;
      const buttons = Array.from(item.querySelectorAll('[data-decision]')) as HTMLButtonElement[];
      const activeLabel = button.querySelector('[data-moderation-approve], [data-moderation-reject]') as HTMLElement | null;
      const activeSpinner = button.querySelector('[data-moderation-approve-spinner], [data-moderation-reject-spinner]') as HTMLElement | null;
      if (!requestId || !galleryItemId || !requestType || !decision || !message || !activeLabel || !activeSpinner) return;

      buttons.forEach((action) => {
        action.disabled = true;
        action.closest('.moderation-action')?.classList.add('is-disabled');
      });
      activeLabel.hidden = true;
      activeSpinner.hidden = false;
      message.textContent = '';
      message.setAttribute('data-type', 'neutral');

      try {
        await decideGalleryModerationRequest({ requestId, galleryItemId, requestType, decision });
        message.textContent = decision === 'APPROVED' ? text.approved : text.rejected;
        message.setAttribute('data-type', 'success');
        item.classList.add('is-resolved');
        window.setTimeout(() => {
          item.remove();
          applyModerationView(reviewList, reviewEmpty);
        }, 520);
      } catch (error: any) {
        message.textContent = error?.message || text.defaultError;
        message.setAttribute('data-type', 'error');
        activeLabel.hidden = false;
        activeSpinner.hidden = true;
        buttons.forEach((action) => {
          action.disabled = false;
          action.closest('.moderation-action')?.classList.remove('is-disabled');
        });
      }
    };

    reviewList.addEventListener('click', onModerationClick);
    disposers.push(() => reviewList.removeEventListener('click', onModerationClick));

    cleanupGalleryReview = () => disposers.forEach((dispose) => dispose());
  }

  document.addEventListener('astro:before-swap', () => {
    cleanupGalleryReview?.();
    cleanupGalleryReview = null;
  });
  document.addEventListener('astro:page-load', initGalleryReviewPage);
  initGalleryReviewPage();
</script>

<style>
  .gallery-admin-page {
    min-height: 100vh;
    padding: 104px clamp(20px, 4vw, 48px) 80px;
    background: var(--bg);
  }

  .gallery-admin-topbar {
    max-width: 1400px;
    margin: 0 auto 44px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    padding-bottom: 16px;
    gap: 18px;
  }

  .gallery-admin-brand {
    display: inline-flex;
    align-items: center;
    gap: 0;
    color: var(--text-strong);
    text-decoration: none;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: 0;
  }

  .gallery-admin-brand__img {
    width: auto;
    height: 42px;
    display: block;
  }

  .gallery-admin-brand__img--light { display: var(--logo-light-display); }
  .gallery-admin-brand__img--dark { display: var(--logo-dark-display); }

  .gallery-admin-topbar :global(.pill),
  .gallery-admin-topbar :global(.btn) {
    width: auto;
  }

  .gallery-admin-topbar :global(.btn) {
    height: 36px;
    padding: 0 18px;
    font-size: 14px;
  }

  .gallery-admin-main {
    display: grid;
    grid-template-columns: 240px minmax(0, 800px);
    justify-content: center;
    gap: clamp(48px, 7vw, 80px);
    max-width: 1400px;
    margin: 0 auto;
  }

  .gallery-admin-identity {
    display: grid;
    gap: 5px;
    margin-bottom: 34px;
  }

  .gallery-admin-identity strong {
    font-size: 18px;
    font-weight: 800;
    color: var(--text-strong);
  }

  .gallery-admin-identity span {
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 600;
    overflow-wrap: anywhere;
  }

  .gallery-admin-content {
    min-width: 0;
    display: grid;
    gap: 16px;
  }

  .panel-title {
    margin: 0 0 6px;
    color: var(--text-strong);
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: 0;
    font-weight: 800;
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .card-copy {
    min-width: 0;
    flex: 1;
  }

  .card-icon {
    width: 42px;
    height: 42px;
    flex: 0 0 42px;
    display: grid;
    place-items: center;
    border-radius: 8px;
    color: var(--color-primary-600);
    background: color-mix(in srgb, var(--surface) 88%, var(--color-primary-500));
  }

  :root.dark .card-icon {
    color: var(--color-primary-300);
    background: color-mix(in srgb, var(--surface) 92%, black);
  }

  :global(.card-icon svg) {
    width: 24px;
    height: 24px;
    display: block;
  }

  .card-head h2 {
    display: block;
    margin: 0;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 0;
    color: var(--text-strong);
  }

  .card-head p {
    display: block;
    margin: 4px 0 0;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 600;
    line-height: 1.45;
    text-wrap: pretty;
  }

  .moderation-item__type {
    background: var(--color-primary-600);
  }

  .moderation-item__type[data-request-type='REMOVAL'] {
    background: #d97706;
  }

  .moderation-item.is-resolved {
    opacity: 0;
    transform: translateY(-6px);
  }

  .submission-empty {
    margin: 18px 0 0;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 700;
  }

  :global(.gallery-card__tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  :global(.gallery-card__tags li) {
    min-width: 0;
    border-radius: 999px;
    padding: 4px 9px;
    color: var(--color-primary-700);
    background: color-mix(in srgb, var(--surface) 76%, var(--color-primary-200));
    font-size: 12px;
    font-weight: 800;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .moderation-reason {
    display: block;
    margin: 0;
    padding: 0;
    border-top: 0;
    border-radius: 0;
    background: transparent;
  }

  .moderation-reason span {
    display: block;
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 650;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .moderation-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .moderation-actions__buttons {
    display: flex;
    justify-content: flex-end;
    gap: 6px;
  }

  :global(.moderation-action) {
    width: auto;
    --pill-radius: 999px;
  }

  :global(.moderation-action.is-disabled) {
    opacity: 0.58;
    pointer-events: none;
  }

  :global(.moderation-action .btn) {
    min-width: 68px;
    height: 32px;
    padding: 0 13px;
    font-size: 12px;
    font-weight: 850;
  }

  .form-message {
    min-height: 16px;
    margin: 0;
    font-size: 12px;
  }

  .form-message[data-type='success'] { color: #059669; }
  .form-message[data-type='error'] { color: #dc2626; }

  .btn-spinner svg {
    animation: btn-spin 0.8s linear infinite;
    display: block;
  }

  @keyframes btn-spin {
    to { transform: rotate(360deg); }
  }

  .gallery-admin-state {
    max-width: 800px;
    margin: 0 auto;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--border) 76%, transparent);
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    padding: 26px;
    color: var(--text-muted);
    font-size: 14px;
