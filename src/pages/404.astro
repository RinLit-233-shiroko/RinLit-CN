---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { defaultLocale, locales, t } from '../i18n/index';

const firstSegment = Astro.url.pathname.split('/').filter(Boolean)[0];
const lang = locales.includes(firstSegment as any) ? firstSegment : defaultLocale;
const __ = (key: string) => t(lang, key);
---

<BaseLayout lang={lang} title={`${__('notFound.title')} — RinLit`} description={__('notFound.desc')}>
  <section class="not-found" aria-labelledby="not-found-title">
    <div class="not-found__shell">
      <h1 id="not-found-title" class="not-found__code">404</h1>
      <p class="not-found__title">{__('notFound.title')}</p>
      <p class="not-found__desc">{__('notFound.desc')}</p>
      <nav class="not-found__actions" aria-label={__('notFound.actions')}>
        <Button primary href={`/${lang}`}>{__('notFound.home')}</Button>
        <Button href={`/${lang}/fields`}>{__('notFound.fields')}</Button>
      </nav>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - 96px);
    display: grid;
    place-items: center;
    padding: 132px 24px 96px;
    color: var(--text);
  }

  .not-found__shell {
    position: relative;
    width: min(100%, 720px);
    display: grid;
    justify-items: center;
    text-align: center;
  }

  .not-found__shell::before {
    content: '';
    position: absolute;
    inset: 20% 12% auto;
    height: 220px;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 22%, transparent) 0%, transparent 68%);
    filter: blur(18px);
    opacity: 0.78;
    pointer-events: none;
  }

  .not-found__code,
  .not-found__title,
  .not-found__desc,
  .not-found__actions {
    position: relative;
  }

  .not-found__code {
    margin: 12px 0 0;
    font-family: 'Plus Jakarta Sans', 'Sarasa SC', sans-serif;
    font-size: clamp(7rem, 22vw, 15rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -0.12em;
    color: var(--text-strong);
  }

  .not-found__title {
    margin: 28px 0 0;
    max-width: 620px;
    font-family: 'Sarasa SC', Geist, sans-serif;
    font-size: clamp(1.7rem, 4vw, 3.25rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text-strong);
  }

  .not-found__desc {
    margin: 20px 0 0;
    max-width: 520px;
    font-size: clamp(0.85rem, 1.6vw, 1rem);
    line-height: 1.8;
    color: var(--text-muted);
  }

  .not-found__actions {
    margin-top: 36px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
  }

  .not-found__actions :global(.pill) {
    min-width: 148px;
  }

  @media (max-width: 640px) {
    .not-found {
      align-items: start;
      padding-top: 124px;
      padding-bottom: 128px;
    }

    .not-found__actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
