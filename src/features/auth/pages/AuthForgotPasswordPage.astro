---
// AuthForgotPasswordPage — 忘记密码页面（Page 3）
//
// 收集用户邮箱，发送密码重置链接。
// 未来可在此页面增加验证码输入步骤。

import { t } from '../../../i18n/index';
import Input from '../../../components/Input.astro';
import Button from '../../../components/Button.astro';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const __ = (key: string) => t(lang, key);
---

<div data-page="3" class="auth-modal__page">
  <div class="auth-modal__forgot-icon">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
    </svg>
  </div>

  <h3 class="auth-modal__forgot-title">{__('auth.forgotPasswordTitle')}</h3>
  <p class="auth-modal__forgot-desc">{__('auth.forgotPasswordDesc')}</p>

  <div class="auth-modal__field">
    <Input
      type="email"
      name="email"
      id="auth-forgot-email"
      placeholder="email@example.com"
      label={__('auth.email')}
      flat
      required
      autocomplete="email"
    />
  </div>

  <p class="auth-modal__error" id="auth-error-forgot" hidden></p>

  <div class="auth-modal__action">
    <Button primary flat class="auth-modal__reset-btn">
      <span class="auth-modal__reset-label">{__('auth.forgotPasswordAction')}</span>
      <span class="auth-modal__submit-spinner" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
        </svg>
      </span>
    </Button>
  </div>

  <p class="auth-modal__switch">
    <button class="auth-modal__switch-btn" data-action="auth:back-to-signin" type="button">
      {__('auth.backToSignIn')}
    </button>
  </p>
</div>
