---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Fields — RinLit">
  <main class="mx-auto flex min-h-screen max-w-5xl items-center px-6">
    <div>
      <p class="text-section-label font-display uppercase tracking-[0.25em] text-primary-600">Fields</p>
      <h1 class="mt-4 text-hero font-display tracking-tight text-dark">领域</h1>
      <p class="mt-6 text-body-large text-neutral-800">创作领域 / 子官网集合</p>
      <nav class="mt-8 flex gap-4">
        <a href="/fields/software" class="rounded-pill border border-neutral-400 px-6 py-2 text-body hover:bg-neutral-100">软件</a>
        <a href="/fields/design" class="rounded-pill border border-neutral-400 px-6 py-2 text-body hover:bg-neutral-100">设计</a>
        <a href="/fields/experiment" class="rounded-pill border border-neutral-400 px-6 py-2 text-body hover:bg-neutral-100">实验</a>
      </nav>
    </div>
  </main>
</BaseLayout>
