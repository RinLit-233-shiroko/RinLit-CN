---
// Figma: FieldsIntro — 深色背景 + 高卡片
// 背景: 深色（接近 neutral-900 或更深）
// 标题: "Explorer the fields." 浅色文字
// 3 张高卡片横排, 背景图填充, 底部渐变遮罩 + 标题/按钮
// AutoPlayControl: PauseButton + PageIndicator 居中

import AutoPlayController from '../../AutoPlayController.astro';
import Button from '../../Button.astro';

const fields = [
  { name: 'Software', href: '/fields/software' },
  { name: 'Design',   href: '/fields/design' },
  { name: 'Lab',      href: '/fields/experiment' },
];
---

<section id="fields" class="bg-light py-24 transition-colors duration-300">
  <!-- 标题区: 受 max-w-6xl 约束 -->
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-title-large font-sans font-bold tracking-tight text-dark">
      Explorer the fields.
    </h2>
  </div>

  <!-- 卡片滚动容器: 填满页面宽度, 无视父级 padding -->
  <div class="fields-scroll mt-10 overflow-x-auto" data-count={fields.length}>
    <div class="fields-cards flex gap-4" style="width: max-content; padding-left: max(24px, calc((100vw - 1152px) / 2)); padding-right: max(24px, calc((100vw - 1152px) / 2));">
      {fields.map((field, i) => (
        <a
          href={field.href}
          class="fields-card group relative flex shrink-0 flex-col justify-end overflow-hidden rounded-3xl"
          data-card={i}
          style="width: min(100vw, 1200px); height: 700px;"
        >
          <!-- 背景图占位 (fill) -->
          <div class="absolute inset-0 bg-neutral-300" data-bg />

          <!-- 底部渐变遮罩伪元素 (在文字按钮下方) -->
          <div class="fields-card__overlay" />

          <!-- 底部内容区: 标题 + 按钮 -->
          <div class="relative z-10 mb-[42px] flex items-center justify-between px-[46px]">
            <span class="fields-card__title">
              {field.name}
            </span>

            <Button variant="default" icon="external-link" flat class="!h-12 !w-12 !px-0" />
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- AutoPlayControl: PauseButton + PageIndicator 居中 -->
  <div class="mt-8 flex items-center justify-center">
    <AutoPlayController count={fields.length} duration={5000} autoplay={true} />
  </div>
</section>

<script>
  // 翻页器切换时, 滚动卡片容器到对应卡片左对齐
  // 监听 #fields (section), 因为 .apc 的 change 事件 bubbles 到这里
  function syncFieldsCards() {
    const section = document.querySelector<HTMLElement>('#fields');
    const scrollContainer = document.querySelector<HTMLElement>('.fields-scroll');
    if (!section || !scrollContainer) return;

    const cardEls = Array.from(scrollContainer.querySelectorAll<HTMLElement>('.fields-card'));
    const cardsInner = document.querySelector<HTMLElement>('.fields-cards');

    section.addEventListener('change', ((e: Event) => {
      const detail = (e as CustomEvent).detail;
      if (!detail || typeof detail.index !== 'number') return;
      const { index } = detail;
      const target = cardEls[index];
      if (!target || !cardsInner) return;

      // 滚动到卡片位置, 减去内层 padding-left 使其左对齐
      const paddingLeft = parseFloat(getComputedStyle(cardsInner).paddingLeft);
      scrollContainer.scrollTo({
        left: target.offsetLeft - paddingLeft,
        behavior: 'smooth',
      });
    }) as EventListener);
  }

  syncFieldsCards();
  document.addEventListener('astro:page-load', syncFieldsCards);
</script>

<style>
  /* 滚动容器: 隐藏滚动条 */
  .fields-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .fields-scroll::-webkit-scrollbar {
    display: none;
  }

  /* 标题字体: Plus Jakarta Sans 粗体 40px */
  .fields-card__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 40px;
    color: #ffffff;
  }

  /* 底部渐变遮罩: 深灰 alpha50% → 黑透明 (由下到上) */
  .fields-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    height: calc(46px + 48px + 42px); /* padding + button-height + margin-bottom */
    background: linear-gradient(
      to top,
      rgba(64, 64, 64, 0.5),
      rgba(0, 0, 0, 0)
    );
    pointer-events: none;
  }
</style>
