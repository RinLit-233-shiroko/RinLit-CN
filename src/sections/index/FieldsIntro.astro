---
import { t } from '../../i18n/index';
import AutoPlayController from '../../components/AutoPlayController.astro';
import Button from '../../components/Button.astro';
import Link from '../../components/Link.astro';

export interface Props {
  lang?: string;
}

const { lang } = Astro.props;
const __ = (key: string) => t(lang, key);

const fields = [
  { name: 'Software', href: 'fields/software' },
  { name: 'Design',   href: 'fields/design' },
  { name: 'Lab',      href: 'fields/experiment' },
];
---

<section id="fields" class="bg-light py-24 transition-colors duration-300">
  <div class="mx-auto max-w-6xl px-6">
    <h2 class="text-title-large font-sans font-bold tracking-tight text-dark">
      {__('fields.title')}
    </h2>
  </div>

  <div class="fields-scroll mt-10 overflow-x-auto" data-count={fields.length}>
    <div class="fields-cards flex gap-4">
      {fields.map((field, i) => (
        <Link
          to={field.href}
          class="fields-card group relative flex shrink-0 flex-col justify-end overflow-hidden rounded-3xl"
          data-card={i}
        >
          <div class="absolute inset-0 bg-neutral-300 bg-cover bg-center" data-bg style="background-image: url('/images/under_construction.png');" />
          <div class="fields-card__overlay" />
          <div class="relative z-10 mb-[42px] flex items-center justify-between px-[46px]">
            <span class="fields-card__title">
              {field.name}
            </span>
            <Button flat icon="external-link" class="linkBtn" />
          </div>
        </Link>
      ))}
    </div>
  </div>

  <div class="mt-8 flex items-center justify-center">
    <AutoPlayController count={fields.length} duration={5000} autoplay={true} />
  </div>
</section>

<script>
  function syncFieldsCards() {
    const section = document.querySelector<HTMLElement>('#fields');
    const scrollContainer = document.querySelector<HTMLElement>('.fields-scroll');
    if (!section || !scrollContainer) return;

    const cardEls = Array.from(scrollContainer.querySelectorAll<HTMLElement>('.fields-card'));

    section.addEventListener('change', ((e: Event) => {
      const detail = (e as CustomEvent).detail;
      if (!detail || typeof detail.index !== 'number') return;
      const target = cardEls[detail.index];
      if (!target) return;
      const snapLeft = parseFloat(getComputedStyle(scrollContainer).scrollPaddingLeft) || 0;
      scrollContainer.scrollTo({
        left: target.offsetLeft - snapLeft,
        behavior: 'smooth',
      });
    }) as EventListener);

    scrollContainer.addEventListener('scrollend', () => {
      const snapLeft = parseFloat(getComputedStyle(scrollContainer).scrollPaddingLeft) || 0;
      const scrollLeft = scrollContainer.scrollLeft;
      let nearestIndex = 0;
      let nearestDist = Infinity;
      cardEls.forEach((card, i) => {
        const dist = Math.abs(card.offsetLeft - snapLeft - scrollLeft);
        if (dist < nearestDist) {
          nearestDist = dist;
          nearestIndex = i;
        }
      });
      section.querySelector<HTMLElement>('.apc')?.dispatchEvent(
        new CustomEvent('apc:command', {
          bubbles: true,
          detail: { command: 'goto', index: nearestIndex },
        }),
      );
    });
  }

  syncFieldsCards();
  document.addEventListener('astro:page-load', syncFieldsCards);
</script>

<style>
  .fields-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x mandatory;
    --side-pad: max(24px, calc((100vw - 1152px) / 2));
    scroll-padding-left: var(--side-pad);
  }
  .fields-scroll::-webkit-scrollbar {
    display: none;
  }

  .fields-cards {
    width: max-content;
    padding-left: var(--side-pad);
    padding-right: var(--side-pad);
  }

  .fields-card {
    width: min(100vw - var(--side-pad) * 2, 1200px);
    height: 700px;
    scroll-snap-align: start;
  }

  .fields-card__title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 700;
    font-size: 40px;
    color: #ffffff;
  }

  :global(.linkBtn) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
  }

  @media (max-width: 1024px) {
    .fields-card {
      height: 460px;
    }
  }

  @media (max-width: 640px) {
    .fields-card {
      height: 400px;
    }
    .fields-card__title {
      font-size: 32px;
    }
    :global(.linkBtn) {
      width: 42px;
      height: 42px;
    }
  }

  .fields-card__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1;
    height: calc(46px + 48px + 42px);
    background: linear-gradient(
      to top,
      rgba(64, 64, 64, 0.5),
      rgba(0, 0, 0, 0)
    );
    pointer-events: none;
  }
</style>
